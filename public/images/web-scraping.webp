" },\n  flutedRoof: { card: \"/images/Aluminium-Fluted-Roof.png\", hero: \"/images/Aluminium-Fluted-Roof.png\" },\n  zincRoof: { card: \"/images/Zinc-Roof.png\", hero: \"/images/Zinc-Roof.png\" },\n  pvcCeiling: { card: \"/images/PVC-Ceiling.png\", hero: \"/images/PVC-Ceiling.png\" },\n  aluminumCeiling: { card: \"/images/Aluminum-Ceiling-False-Ceiling.png\", hero: \"/images/Aluminum-Ceiling-False-Ceiling.png\" },\n  metalWork: { card: \"/images/Metal-Work.png\", hero: \"/images/Metal-Work.png\" },\n  woodenTrellis: { card: \"/images/Wooden-Trellis.png\", hero: \"/images/Wooden-Trellis.png\" },\n  woodenDecking: { card: \"/images/Wooden-Decking.png\", hero: \"/images/Wooden-Decking.png\" },\n  renovation: { card: \"/images/Renovation-General-Contractor.png\", hero: \"/images/Renovation-General-Contractor.png\" },\n};\n\nexport const SERVICES = [\n  { slug: \"retractable-awning\", title: \"Retractable Awning\", desc: \"Motorized/manual retractable awnings for homes, shops and outdoor seating.\", seoTitle: \"Retractable Awning Singapore (Motorized / Manual) | Din Lee Engineering\", seoDesc: \"Custom retractable awnings in Singapore for homes and shops. Site measurement, fabrication and installation. Call +65 8530 3990.\", cardImage: SERVICE_IMAGES.retractableAwning.card, heroImage: SERVICE_IMAGES.retractableAwning.hero },\n  { slug: \"loop-awning\", title: \"Loop Awning\", desc: \"Elegant loop awnings for storefronts and walkways with strong frame support.\", seoTitle: \"Loop Awning Singapore | Shopfront and Walkway Awnings | Din Lee\", seoDesc: \"Loop awning supply and installation in Singapore for storefronts and walkways. Call +65 8530 3990.\", cardImage: SERVICE_IMAGES.loopAwning.card, heroImage: SERVICE_IMAGES.loopAwning.hero },\n  { slug: \"rooftop-awnings\", title: \"Rooftop Awnings\", desc: \"Rooftop shade systems engineered for wind and rain conditions in Singapore.\", seoTitle: \"Rooftop Awnings Singapore | Rooftop Shade Systems | Din Lee\", seoDesc: \"Rooftop awning and shade solutions in Singapore. Site assessment, fabrication and installation. Call +65 8530 3990.\", cardImage: SERVICE_IMAGES.rooftopAwnings.card, heroImage: SERVICE_IMAGES.rooftopAwnings.hero },\n  { slug: \"glass-canopy\", title: \"Glass Canopy Shelter\", desc: \"Modern glass canopy shelters with safety glass and robust metal structure.\", seoTitle: \"Glass Canopy Shelter Singapore | Safety Glass Canopy | Din Lee\", seoDesc: \"Modern glass canopy shelter supply and installation in Singapore. Call +65 8530 3990.\", cardImage: SERVICE_IMAGES.glassCanopy.card, heroImage: SERVICE_IMAGES.glassCanopy.hero },\n  { slug: \"sunshade\", title: \"Sunshade / Shade Solution\", desc: \"Custom sunshade solutions for residential, commercial and industrial spaces.\", seoTitle: \"Sunshade and Shade Solution Singapore | Outdoor Shade | Din Lee\", seoDesc: \"Custom sunshade and shade solutions in Singapore. Measurement, fabrication and installation. Call +65 8530 3990.\", cardImage: SERVICE_IMAGES.sunshade.card, heroImage: SERVICE_IMAGES.sunshade.hero },\n  { slug: \"outdoor-zip-track\", title: \"Outdoor Zip Track\", desc: \"Zip track systems for balconies and patios with comfort and privacy control.\", seoTitle: \"Outdoor Zip Track Singapore | Balcony Zip Track System | Din Lee\", seoDesc: \"Outdoor zip track systems in Singapore for balconies and patios. Call +65 8530 3990.\", cardImage: SERVICE_IMAGES.zipTrack.card, heroImage: SERVICE_IMAGES.zipTrack.hero },\n  { slug: \"roller-blind\", title: \"Outdoor Roller Blind\", desc: \"Outdoor roller blinds to reduce glare, heat and improve privacy.\", seoTitle: \"Outdoor Roller Blind Singapore | Heat and Glare Control | Din Lee\", seoDesc: \"Outdoor roller blinds in Singapore for heat control, glare reduction and privacy. Call +65 8530 3990.\", cardImage: SERVICE_IMAGES.rollerBlind.card, heroImage: SERVICE_IMAGES.rollerBlind.hero },\n  { slug: \"acp-roof\", title: \"ACP Roof\", desc: \"ACP roofing with clean finishing, durability and waterproofing options.\", seoTitle: \"ACP Roof Singapore | Aluminium Composite Panel Roofing | Din Lee\", seoDesc: \"ACP roofing in Singapore with clean finishing and waterproofing options. Call +65 8530 3990.\", cardImage: SERVICE_IMAGES.acpRoof.card, heroImage: SERVICE_IMAGES.acpRoof.hero },\n  { slug: \"polycarbonate-roof\", title: \"Polycarbonate Roof\", desc: \"Lightweight polycarbonate roofing for patios, car porches and walkways.\", seoTitle: \"Polycarbonate Roof Singapore | Patio and Car Porch Roofing | Din Lee\", seoDesc: \"Polycarbonate roofing in Singapore for patios, car porches and walkways. Call +65 8530 3990.\", cardImage: SERVICE_IMAGES.polyRoof.card, heroImage: SERVICE_IMAGES.polyRoof.hero },\n  { slug: \"aluminium-fluted-roof\", title: \"Aluminium Fluted Roof\", desc: \"Premium fluted aluminium roof panels for modern outdoor aesthetics.\", seoTitle: \"Aluminium Fluted Roof Singapore | Premium Outdoor Roof | Din Lee\", seoDesc: \"Aluminium fluted roof installation in Singapore. Measurement, fabrication and installation. Call +65 8530 3990.\", cardImage: SERVICE_IMAGES.flutedRoof.card, heroImage: SERVICE_IMAGES.flutedRoof.hero },\n  { slug: \"zinc-roof\", title: \"Zinc Roof\", desc: \"Zinc roofing solutions with corrosion resistance and neat finish.\", seoTitle: \"Zinc Roof Singapore | Corrosion Resistant Roofing | Din Lee\", seoDesc: \"Zinc roof installation in Singapore with neat finish. Call +65 8530 3990.\", cardImage: SERVICE_IMAGES.zincRoof.card, heroImage: SERVICE_IMAGES.zincRoof.hero },\n  { slug: \"pvc-ceiling\", title: \"Wood Grain Ceiling\", desc: \"Wood grain ceiling for interior and exterior areas with easy maintenance.\", seoTitle: \"Wood Grain Ceiling Singapore | Easy Maintenance Ceiling Works | Din Lee\", seoDesc: \"Wood grain ceiling works in Singapore for clean look and easy maintenance. Call +65 8530 3990.\", cardImage: SERVICE_IMAGES.pvcCeiling.card, heroImage: SERVICE_IMAGES.pvcCeiling.hero },\n  { slug: \"aluminum-ceil