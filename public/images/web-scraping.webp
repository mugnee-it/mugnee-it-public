export const CLUSTERS = [{
  slug: "awning-singapore",
  title: "Awning Singapore",
  seoTitle: "Awning Singapore | Din Lee Engineering",
  seoDescription: "Awning Singapore contractor for homes and shops. Learn the benefits, pricing factors, and why Din Lee Engineering is trusted.",
  intro: "Searching for awning Singapore usually means you need better shade, rain protection, or a cleaner covered outdoor area. This page explains what an awning is, why it is useful in Singapore weather, what benefits you get, and why clients choose Din Lee Engineering for proper survey, fabrication, installation, and after-sales support.",
  heroImage: "/images/Awning-Shade-Solutions.png",
  primaryKeyword: "awning singapore",
  relatedKeywords: ["awning contractor singapore", "awning installation singapore", "outdoor awning singapore", "balcony awning singapore"],
  buyingSignals: ["Site survey included", "After-sales support", "Experienced engineering team"],
  benefitPoints: ["Creates practical shade for balconies, patios, walkways, and shopfronts.", "Reduces sun glare and heat so outdoor areas stay usable for longer hours.", "Adds rain shelter to entrances and seating zones in Singapore weather.", "Improves the look of the property with a cleaner and more finished facade."],
  whyChooseUs: ["We recommend the right awning type based on sun direction, rain exposure, and fixing condition.", "Our engineering team checks mounting strength, drainage direction, and structural support before fabrication.", "Clients get clear material guidance, practical pricing advice, and clean finishing.", "We provide after-sales support for adjustment guidance, care advice, and follow-up questions."],
  processSteps: ["Share postcode, photos, and rough size so we can review the requirement quickly.", "We carry out site survey and check measurement, support points, and drainage.", "Our team proposes the suitable awning type, materials, and quotation.", "Fabrication and installation are completed with alignment, support, and finishing checks."],
  h1: "Awning Singapore",
  sections: [{
    title: "What Is Awning Singapore",
    body: "Awning Singapore usually refers to a shade or shelter system installed above balconies, patios, windows, entrances, walkways, or shopfronts. Some awnings are fixed while others are retractable. In Singapore, they are commonly chosen because outdoor spaces become uncomfortable without proper protection from strong sun and frequent rain."
  }, {
    title: "Why People Need Awning Singapore",
    body: "Without an awning, many outdoor areas stay too hot during the day and too exposed during rain. Buyers usually install awning Singapore solutions to make balconies more usable, protect doors and windows, create covered seating, and improve comfort for family members, customers, or staff."
  }, {
    title: "Benefits Of Installing An Awning",
    body: "A well-planned awning gives shade, rain protection, lower glare, and better daily usability. It can also help reduce heat near doors and windows, keep entrance zones drier, and create a more polished exterior look for the property."
  }, {
    title: "Who Should Consider Awning Singapore",
    body: "Awning Singapore is suitable for condo balconies, landed homes, retail shops, cafes, commercial entrances, and industrial covered areas. If you have an exposed outdoor space that is underused because of weather, an awning is often one of the most practical upgrades."
  }, {
    title: "What To Check Before Choosing An Awning Contractor",
    body: "Do not choose based on price alone. The contractor should inspect the mounting surface, projection depth, drainage direction, frame support, and finishing details. Weak fixing and poor slope planning often cause long-term problems. Din Lee Engineering focuses on site-based recommendations, not generic quotations."
  }, {
    title: "Why Choose Din Lee Engineering",
    body: "Clients choose Din Lee Engineering Pte. Ltd. because we combine practical engineering review with fabrication and installation experience. We explain suitable options clearly, work with Singapore weather conditions in mind, maintain workmanship standards during installation, and continue supporting clients after handover when adjustments or maintenance advice are needed."
  }, {
    title: "Awning Singapore Price Factors",
    body: "Awning Singapore pricing depends on width, projection, material type, frame design, motorisation where applicable, site access, and mounting complexity. A faster quotation is possible when you send your postcode, site photos, and rough dimensions."
  }],
  faq: [{
    q: "Why is awning Singapore useful for homes and shops?",
    a: "It improves shade, rain protection, and comfort for outdoor areas that are otherwise too exposed for daily use."
  }, {
    q: "Does Din Lee Engineering provide after-sales support?",
    a: "Yes. We provide after-sales guidance, answer follow-up questions, and support clients after installation."
  }, {
    q: "How do I get a quote for awning Singapore?",
    a: `Send your location, photos, and rough size to ${SITE.phone} so we can review the site and advise the next step quickly.`
  }],
  relatedServiceSlugs: ["retractable-awning", "loop-awning", "rooftop-awnings", "sunshade"]
}, {
  slug: "retractable-awning-singapore",
  title: "Retractable Awning Singapore",
  seoTitle: "Retractable Awning Singapore | Din Lee",
  seoDescription: "Retractable Awning Singapore solutions for balconies, patios, and shopfronts. Learn the benefits and why Din Lee Engineering is trusted.",
  intro: "Retractable awning Singapore is a strong search term because buyers already know they want flexible shade. This page explains why retractable awnings are popular, when they are the right choice, what benefits they give, and how Din Lee Engineering delivers strong support from survey to after-sales service.",
  heroImage: "/images/Retractable-Awning.png",
  primaryKeyword: "retractable awning singapore",
  relatedKeywords: ["motorised retractable awning singapore", "manual retractable awning singapore", "balcony retractable awning singapore", "patio retractable awning singapore"],
  buyingSignals: ["Manual or motorised", "Neat installation", "After-sales support"],
  benefitPoints: ["Opens when shade is needed and retracts when you want more light or open sky.", "Works well for balconies, patios, cafes, terraces, and shopfront seating areas.", "Improves daily convenience, especially with motorised systems.", "Keeps the facade cleaner than some heavier fixed structures."],
  whyChooseUs: ["We check wall strength, retraction clearance, and projection depth before recommending a system.", "Our engineering team advises whether manual or motorised operation suits the opening size and usage.", "We focus on stable mounting, smooth movement, and clean alignment during installation.", "After handover, clients can still contact us for care advice and support."],
  processSteps: ["We review your site photos, width, and projection requirement.", "A site survey confirms mounting condition, clearance, and preferred operation type.", "We recommend the right retractable awning system and issue quotation.", "Fabrication, installation, testing, and final handover are completed by our team."],
  h1: "Retractable Awning Singapore",
  sections: [{
    title: "What Is Retractable Awning Singapore",
    body: "Retractable awning Singapore refers to an awning system that can extend or fold back depending on weather and daily use. It is commonly installed for balconies, patios, terraces, cafes, and shopfronts where flexible coverage is more useful than permanent full cover."
  }, {
    title: "Why Buyers Prefer Retractable Systems",
    body: "Many people do not want fixed shade all day. A retractable awning gives control. You can extend it in harsh sun or light rain and retract it when you want more brightness, view, or airflow. That flexibility makes it a smart choice for mixed-use outdoor areas."
  }, {
    title: "Main Benefits For Homes And Businesses",
    body: "The biggest benefits are flexible shade, easier daily comfort, cleaner appearance, and better control over the outdoor environment. Motorised systems add convenience for larger spans and premium spaces where regular use matters."
  }, {
    title: "Manual Vs Motorised Retractable Awning",
    body: "Manual systems can suit smaller openings and tighter budgets. Motorised retractable awning Singapore systems are better for larger widths, more frequent use, and clients who want easier operation. The right option depends on budget, convenience, and size."
  }, {
    title: "What Makes A Good Installation",
    body: "A good installation starts with proper wall assessment, projection planning, and retraction clearance. Poor alignment or weak fixing can reduce long-term performance. Din Lee Engineering checks structure first so the finished system looks neat and operates smoothly."
  }, {
    title: "Why Choose Din Lee Engineering",
    body: "Our team does not just install the awning. We assess the site, explain system options clearly, recommend a suitable frame and operation type, and complete the work with workmanship checks. We also provide after-sales support so clients are not left alone after handover."
  }, {
    title: "Retractable Awning Singapore Price Factors",
    body: "Price depends on width, projection, manual or motorised setup, arm system, frame quality, access condition, and finishing details. Send your photos and rough size for faster budget guidance."
  }],
  faq: [{
    q: "Why choose a retractable awning instead of a fixed awning?",
    a: "Because it gives you flexible shade control. You can open it when needed and retract it when you want more light or open space."
  }, {
    q: "Is motorised retractable awning worth it?",
    a: "It is usually worth it for larger systems, premium spaces, and clients who want smoother and easier daily use."
  }, {
    q: "Do you provide after-sales support for retractable awnings?",
    a: "Yes. We support clients after installation with operating guidance and follow-up support when needed."
  }],
  relatedServiceSlugs: ["retractable-awning", "sunshade", "rooftop-awnings"]
}];
