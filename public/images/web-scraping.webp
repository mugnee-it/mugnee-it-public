ACnB;YAAK,GAJNmB,IAAI,CAAC/B,IAAI;cAAAuB,QAAA,EAAAC,YAAA;cAAAC,UAAA;cAAAC,YAAA;YAAA,OAKV,CACP;UAAC;YAAAH,QAAA,EAAAC,YAAA;YAAAC,UAAA;YAAAC,YAAA;UAAA,OACC,CAAC;QAAA;UAAAH,QAAA,EAAAC,YAAA;UAAAC,UAAA;UAAAC,YAAA;QAAA,OACH,CAAC,eAENhC,OAAA;UAAK2B,SAAS,EAAC,2EAA2E;UAAAC,QAAA,gBACxF5B,OAAA;YAAI2B,SAAS,EAAC,wBAAwB;YAAAC,QAAA,EAAC;UAAoB;YAAAC,QAAA,EAAAC,YAAA;YAAAC,UAAA;YAAAC,YAAA;UAAA,OAAI,CAAC,eAChEhC,OAAA;YAAG2B,SAAS,EAAC,4CAA4C;YAAAC,QAAA,EAAC;UAG1D;YAAAC,QAAA,EAAAC,YAAA;YAAAC,UAAA;YAAAC,YAAA;UAAA,OAAG,CAAC,eACJhC,OAAA;YACEwE,IAAI,EAAE,OAAO3E,IAAI,CAAC4E,KAAK,CAACC,OAAO,CAAC,KAAK,EAAE,EAAE,CAAC,EAAG;YAC7C/C,SAAS,EAAC,6FAA6F;YAAAC,QAAA,GACxG,OACM,EAAC/B,IAAI,CAAC4E,KAAK;UAAA;YAAA5C,QAAA,EAAAC,YAAA;YAAAC,UAAA;YAAAC,YAAA;UAAA,OACf,CAAC;QAAA;UAAAH,QAAA,EAAAC,YAAA;UAAAC,UAAA;UAAAC,YAAA;QAAA,OACD,CAAC;MAAA;QAAAH,QAAA,EAAAC,YAAA;QAAAC,UAAA;QAAAC,YAAA;MAAA,OACD,CAAC;IAAA;MAAAH,QAAA,EAAAC,YAAA;MAAAC,UAAA;MAAAC,YAAA;IAAA,OACD,CAAC;EAAA,eACV,CAAC;AAEP;AAACpB,EAAA,CA1QuBD,WAAW;EAAA,QACLlB,SAAS,EAChBD,WAAW,EAKhCM,UAAU;AAAA;AAAA6E,EAAA,GAPYhE,WAAW;AAAA,IAAAgE,EAAA;AAAAC,YAAA,CAAAD,EAAA,iB","sourcesContent":["import { Link, useLocation, useParams } from \"react-router-dom\";\nimport { CLUSTERS, getClusterBySlug } from \"../data/clusters\";\nimport { SERVICES, SITE } from \"../data/site\";\nimport usePageSeo from \"../hooks/usePageSeo\";\n\nfunction findServicesBySlugs(slugs) {\n  return slugs\n    .map((slug) => SERVICES.find((service) => service.slug === slug))\n    .filter(Boolean);\n}\n\nexport default function ClusterPage() {\n  const { slug: routeSlug } = useParams();\n  const { pathname } = useLocation();\n  const resolvedSlug =\n    routeSlug || pathname.split(\"/\").filter(Boolean)[1] || \"\";\n  const cluster = getClusterBySlug(resolvedSlug);\n\n  usePageSeo({\n    title: cluster ? cluster.seoTitle : `Services Singapore | ${SITE.brand}`,\n    description: cluster\n      ? cluster.seoDescription\n      : `Explore service guides and contractor pages by ${SITE.brand} in Singapore.`,\n    canonicalUrl: cluster ? `${SITE.domain}/services/${cluster.slug}` : `${SITE.domain}/services`,\n    ogImage: `${SITE.domain}${cluster?.heroImage || \"/images/company-logo.png\"}`,\n  });\n\n  if (!cluster) {\n    return (\n      <div className=\"max-w-4xl mx-auto px-4 py-16\">\n        <h1 className=\"text-3xl font-extrabold text-slate-900\">Cluster page not found</h1>\n        <p className=\"mt-3 text-slate-600\">The requested page does not exist.</p>\n        <Link to=\"/services\" className=\"mt-6 inline-block text-blue-600 font-semibold\">\n          Back to Services\n        </Link>\n      </div>\n    );\n  }\n\n  const relatedServices = findServicesBySlugs(cluster.relatedServiceSlugs || []);\n  const siblingClusters = CLUSTERS.filter((item) => item.slug !== cluster.slug).slice(0, 5);\n  const benefitPoints = cluster.benefitPoints || [];\n  const whyChooseUs = cluster.whyChooseUs || [];\n  const processSteps = cluster.processSteps || [];\n  const buyingSignals = cluster.buyingSignals || [];\n  const pageSchema = {\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"WebPage\",\n    name: cluster.title,\n    url: `${SITE.domain}/services/${cluster.slug}`,\n    description: cluster.seoDescription,\n  };\n  const breadcrumbSchema = {\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"BreadcrumbList\",\n    itemListElement: [\n      { \"@type\": \"ListItem\", position: 1, name: \"Home\", item: SITE.domain },\n      { \"@type\": \"ListItem\", position: 2, name: \"Services\", item: `${SITE.domain}/services` },\n      { \"@type\": \"ListItem\", position: 3, name: cluster.title, item: `${SITE.domain}/services/${cluster.slug}` },\n    ],\n  };\n  const faqSchema = {\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"FAQPage\",\n    mainEntity: cluster.faq.map((item) => ({\n      \"@type\": \"Question\",\n      name: item.q,\n      acceptedAnswer: {\n        \"@type\": \"Answer\",\n        text: item.a,\n      },\n    })),\n  };\n\n  return (\n    <>\n      <script type=\"application/ld+json\">{JSON.stringify(pageSchema)}</script>\n      <script type=\"application/ld+json\">{JSON.stringify(breadcrumbSchema)}</script>\n      <script type=\"application/ld+json\">{JSON.stringify(faqSchema)}</script>\n\n      <section className=\"bg-gradient-to-b from-slate-50 to-white border-b\">\n        <div className=\"max-w-6xl mx-auto px-4 py-12 grid lg:grid-cols-2 gap-8 items-center\">\n          <div>\n            <div className=\"text-sm text-slate-600\">\n              <Link to=\"/\" className=\"hover:text-slate-900\">Home</Link>\n              <span className=\"mx-2\">/</span>\n              <Link to=\"/services\" className=\"hover:text-slate-900\">Services</Link>\n              <span className=\"mx-2\">/</span>\n              <span className=\"font-semibold text-slate-900\">{cluster.title}</span>\n            </div>\n\n            <h1 className=\"mt-4 text-3xl md:text-5xl font-extrabold text-slate-900\">\n              {cluster.h1}\n            </h1>\n\n            <p className=\"mt-4 text-slate-600 leading-relaxed\">{cluster.intro}</p>\n\n            <div className=\"mt-5 flex flex-wrap gap-2\">\n              {[cluster.primaryKeyword, ...cluster.relatedKeywords].map((item) => (\n                <span\n                  key={item}\n                  className=\"rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700\"\n                >\n                  {item}\n                </span>\n              ))}\n            </div>\n\n            <div className=\"mt-7 flex flex-wrap gap-3\">\n              <Link\n                to=\"/contact\"\n                className=\"rounded-xl bg-blue-600 px-5 py-3 font-bold text-white hover:bg-blue-700 transition\"\n              >\n                Request Quote\n              </Link>\n              <Link\n                to=\"/services\"\n                className=\"rounded-xl border border-slate-300 px-5 py-3 font-bold text-slate-900 hover:bg-slate-50 