AA;cAAAC,YAAA;YAAA,OAAO,CAAC,eACrBnF,OAAA;cAAMoF,SAAS,EAAC,iDAAiD;cAAAV,QAAA,EAAC;YAAC;cAAAM,QAAA,EAAAC,YAAA;cAAAC,UAAA;cAAAC,YAAA;YAAA,OAAM,CAAC;UAAA;YAAAH,QAAA,EAAAC,YAAA;YAAAC,UAAA;YAAAC,YAAA;UAAA,OACnE,CAAC,eACVnF,OAAA;YAAGoF,SAAS,EAAC,6CAA6C;YAAAV,QAAA,EAAE3B,IAAI,CAACd;UAAC;YAAA+C,QAAA,EAAAC,YAAA;YAAAC,UAAA;YAAAC,YAAA;UAAA,OAAI,CAAC;QAAA,GAL3DpC,IAAI,CAACf,CAAC;UAAAgD,QAAA,EAAAC,YAAA;UAAAC,UAAA;UAAAC,YAAA;QAAA,OAMX,CACV;MAAC;QAAAH,QAAA,EAAAC,YAAA;QAAAC,UAAA;QAAAC,YAAA;MAAA,OACC,CAAC;IAAA;MAAAH,QAAA,EAAAC,YAAA;MAAAC,UAAA;MAAAC,YAAA;IAAA,OACC,CAAC,eAEVnF,OAAA;MAASoF,SAAS,EAAC,cAAc;MAAAV,QAAA,eAC/B1E,OAAA;QAAKoF,SAAS,EAAC,gFAAgF;QAAAV,QAAA,gBAC7F1E,OAAA;UAAA0E,QAAA,gBACE1E,OAAA;YAAIoF,SAAS,EAAC,yBAAyB;YAAAV,QAAA,EAAC;UAAoB;YAAAM,QAAA,EAAAC,YAAA;YAAAC,UAAA;YAAAC,YAAA;UAAA,OAAI,CAAC,eACjEnF,OAAA;YAAGoF,SAAS,EAAC,oBAAoB;YAAAV,QAAA,EAAC;UAElC;YAAAM,QAAA,EAAAC,YAAA;YAAAC,UAAA;YAAAC,YAAA;UAAA,OAAG,CAAC;QAAA;UAAAH,QAAA,EAAAC,YAAA;UAAAC,UAAA;UAAAC,YAAA;QAAA,OACD,CAAC,eAENnF,OAAA;UAAKoF,SAAS,EAAC,uGAAuG;UAAAV,QAAA,eACpH1E,OAAA;YACEuF,GAAG,EAAE/E,MAAM,CAACI,KAAM;YAClB4E,GAAG,EAAC,0EAA0E;YAC9EJ,SAAS,EAAC,0BAA0B;YACpCK,OAAO,EAAC,MAAM;YACdC,OAAO,EAAGC,CAAC,IAAK;cACdA,CAAC,CAACC,aAAa,CAACL,GAAG,GAAG/E,MAAM,CAACK,QAAQ;YACvC;UAAE;YAAAmE,QAAA,EAAAC,YAAA;YAAAC,UAAA;YAAAC,YAAA;UAAA,OACH;QAAC;UAAAH,QAAA,EAAAC,YAAA;UAAAC,UAAA;UAAAC,YAAA;QAAA,OACC,CAAC,eAENnF,OAAA;UAAKoF,SAAS,EAAC,iEAAiE;UAAAV,QAAA,gBAC9E1E,OAAA;YACEsF,IAAI,EAAE,OAAO5F,IAAI,CAACwC,KAAK,EAAG;YAC1BkD,SAAS,EAAC,mGAAmG;YAAAV,QAAA,GAC9G,OACM,EAAChF,IAAI,CAACwC,KAAK;UAAA;YAAA8C,QAAA,EAAAC,YAAA;YAAAC,UAAA;YAAAC,YAAA;UAAA,OACf,CAAC,eAEJnF,OAAA,CAACR,IAAI;YACH6F,EAAE,EAAC,UAAU;YACbD,SAAS,EAAC,4GAA4G;YAAAV,QAAA,EACvH;UAED;YAAAM,QAAA,EAAAC,YAAA;YAAAC,UAAA;YAAAC,YAAA;UAAA,OAAM,CAAC;QAAA;UAAAH,QAAA,EAAAC,YAAA;UAAAC,UAAA;UAAAC,YAAA;QAAA,OACJ,CAAC;MAAA;QAAAH,QAAA,EAAAC,YAAA;QAAAC,UAAA;QAAAC,YAAA;MAAA,OACH;IAAC;MAAAH,QAAA,EAAAC,YAAA;MAAAC,UAAA;MAAAC,YAAA;IAAA,OACC,CAAC;EAAA,eACV,CAAC;AAEP;AAAC/E,EAAA,CAtjBuBD,QAAQ;EAAA,QAkB9BL,UAAU;AAAA;AAAA0G,EAAA,GAlBYrG,QAAQ;AAAA,IAAAqG,EAAA;AAAAC,YAAA,CAAAD,EAAA,c","sourcesContent":["import { useMemo } from \"react\";\nimport { Link } from \"react-router-dom\";\nimport { CLUSTERS } from \"../data/clusters\";\nimport { SITE, SERVICES, servicesIndexUrl } from \"../data/site\";\nimport ServiceCard from \"../components/ServiceCard\";\nimport usePageSeo from \"../hooks/usePageSeo\";\n\nexport default function Services() {\n  const PAGE_URL = servicesIndexUrl();\n  const SEO_TITLE =\n    \"Awnings, Roofing, Shelter, Zip Track & Metal Works in Singapore | Din Lee Engineering\";\n  const SEO_DESC =\n    \"Din Lee Engineering provides retractable awnings, rooftop awnings, loop awnings, shelters, glass canopy, ACP and polycarbonate roofing, outdoor zip track, roller blinds, metal works, decking and renovation support in Singapore.\";\n\n  const IMAGES = useMemo(\n    () => ({\n      hero: \"/images/glass.jpg\",\n      process: \"/images/process.png\",\n      materials: \"/images/Where-services.png\",\n      quote: \"/images/Need-Fast-Quotation.png\",\n      fallback: \"/images/glass.jpg\",\n    }),\n    []\n  );\n\n  usePageSeo({\n    title: SEO_TITLE,\n    description: SEO_DESC,\n    canonicalUrl: PAGE_URL,\n    ogImage: `${SITE.domain}/images/company-logo.png`,\n  });\n\n  const CONTENT = useMemo(\n    () => ({\n      trustBullets: [\n        \"Singapore site advice based on heat, rain and wind exposure.\",\n        \"Accurate site measurement, fabrication and installation.\",\n        \"Material guidance for ACP, polycarbonate, zinc and glass canopy.\",\n        \"After-sales support with practical maintenance advice.\",\n      ],\n      processSteps: [\n        {\n          h: \"1. Share Site Details\",\n          p: \"Send your postcode, photos and rough measurements. We review the area use, sun direction and rain exposure before suggesting suitable awning, roof or shelter options.\",\n        },\n        {\n          h: \"2. Site Survey\",\n          p: \"We inspect fixing points, wall condition, drainage path, access and clearance so the final structure fits properly and performs well in Singapore weather.\",\n        },\n        {\n          h: \"3. Quote and Scope\",\n          p: \"You receive practical recommendations, material options and pricing direction based on size, structure type, finishing requirement and site complexity.\",\n        },\n        {\n          h: \"4. Fabrication Work\",\n          p: \"Our fabrication stage focuses on support strength, neat joints, accurate sizing and finishing details that reduce leakage, vibration and misalignment risk.\",\n        },\n        {\n          h: \"5. Install and Handover\",\n          p: \"We complete installation, alignment, sealing and final checks before handover. Basic care guidance is shared so the system stays durable for daily use.\",\n        },\n      ],\n      keywordSections: [\n        {\n          h: \"Retractable Awning Singapore Guide\",\n          p: \"Retractable awnings are suitable for balconies, patios, shopfronts and outdoor seating zones where flexible shade is important. We advise on projection depth, fabric quality, motorized or manual operation, and fixing method based on the actual wall condition and weather exposure.\",\n        },\n        {\n          h: \"Polycarbonate Roof Singapore Guide\",\n          p: \"Polycarbonate roofing is widely chosen for car porch roofs, patio covers and side walkways because it is lightweight, weather resistant and practical for natural light. We help you choose sheet thickness, color tint, support spacing and drainage slope for cleaner long-term performance.\",\n        },\n        {\n          h: \"Zip Track Singapore Guide\",\n          p: \"Outdoor zip track systems are ideal for balcony privacy, sun control and rain protection. We assess the opening width, side track layout, wind exposure and control type so the screen moves smoothly and stays stable during regular use.\",\n        },\n        {\n          h: \"Glass Canopy Singapore Guide\",\n          p: \"Glass canopy shelters are commonly used for entrances, walkways and facade protection where a premium look matters. The right glass type, support bracket design and waterproof detailing are important for safety, drainage and overall finishing quality.\",\n        },\n        {\n          h: \"Metal Work Singapore Guide\",\n          p: \"Custom metal work supports many outdoor projects including brackets, frames, support posts and structure reinforcement. Our recommendations depend on load, fixing points, finish coating and the relationship between the metal frame and roof or canopy material.\",\n        },\n      ],\n      materials: [\n        {\n          h: \"Roofing Materials for Singapore\",\n          p: \"We commonly work with ACP roofing, polycarbonate sheets, zinc roofing, aluminum components, coated metal structures and safety glass systems. Material selection depends on heat control, drainage, maintenance level, design preference and required lifespan.\",\n        },\n        {\n          h: \"Best Material for Each Site\",\n          p: \"Different spaces require different solutions. A balcony may need zip track and roller blind support, while a car porch may benefit from polycarbonate or ACP roofing. We match the material to the site function, exposure and budget rather than forcing one option everywhere.\",\n        },\n      ],\n      pricingFactors: [\n        {\n          h: \"Awning and Roofing Price Factors\",\n          items: [\n            \"Width, projection, height and total coverage area.\",\n            \"Material choice such as ACP, polycarbonate, zinc or glass.\",\n            \"Frame design, support count and structural complexity.\",\n            \"Access condition, scaffold or lift requirement, and safety setup.\",\n            \"Motorized systems, side covers, drainage and edge finishing.\",\n          ],\n        },\n        {\n          h: \"Fast Quote Details\",\n          items: [\n            \"Location or postcode.\",\n            \"Front and side photos of the area.\",\n            \"Approximate width, height and projection.\",\n            \"Preferred service type and key problem to solve.\",\n          ],\n        },\n      ],\n      useCases: [\n        \"HDB and condo balconies for sun, rain and privacy control.\",\n        \"Landed homes for car porch roofs, patios and side walkways.\",\n        \"Retail and commercial fronts for loop awning and canopy coverage.\",\n        \"Industrial and warehouse spaces for functional shelter and roofing.\",\n      ],\n      areas: [\n        {\n          h: \"Areas We Serve in Singapore\",\n          p: \"We support residential, commercial and industrial clients across Singapore. For faster scheduling, send your postcode and photos so we can advise whether remote quoting is enough or a site visit is better.\",\n        },\n      ],\n      compare: {\n        h: \"Compare Our Workmanship\",\n        rows: [\n          [\"Site survey\", \"Measured on site with recommendations\", \"Often estimate based\"],\n          [\"Material advice\", \"Matched to exposure and budget\", \"Often generic advice\"],\n          [\"Drainage detail\", \"Slope and sealing are planned\", \"May be overlooked\"],\n          [\"Support strength\", \"Frame and fixing are reviewed\", \"Can be minimal\"],\n          [\"After-sales help\", \"Guidance and follow-up support\", \"Often limited\"],\n        ],\n      },\n    }),\n    []\n  );\n\n  const FAQ = useMemo(\n    () => [\n      {\n        q: \"What services do you provide in Singapore?\",\n        a: \"We provide retractable awnings, loop awnings, rooftop awnings, glass canopy shelters, ACP roofing, polycarbonate roofing, zinc roofing, outdoor zip track, roller blinds, ceilings, metal works, wooden decking, trellis and renovation support.\",\n      },\n      {\n        q: \"Do you offer site measurement and installation?\",\n        a: \"Yes. We arrange site measurement, recommend suitable materials and structure types, then handle fabrication and installation with finishing checks.\",\n      },\n      {\n        q: \"Which material is best for Singapore weather?\",\n        a: \"That depends on sun exposure, rain direction, wind corridor, maintenance expectations and budget. Common options include ACP, polycarbonate, zinc, aluminum and glass canopy systems.\",\n      },\n      {\n        q: \"How can I get a fast quotation?\",\n        a: \"Send your location, photos, approximate size and preferred service type. We will review the requirement and suggest the next step quickly.\",\n      },\n      {\n        q: \"Do you serve homes and commercial sites?\",\n        a: \"Yes. We support homes, shopfronts, offices, walkways, factories and other outdoor covered spaces across Singapore.\",\n      },\n      {\n        q: \"How do I contact Din Lee Engineering?\",\n        a: `Call or WhatsApp ${SITE.phone}, or email ${SITE.emailPrimary}. Working hours are Monday to Saturday, 9am to 6pm.`,\n      },\n    ],\n    []\n  );\n\n  const schemas = useMemo(() => {\n    const itemList = {\n      \"@context\": \"https://schema.org\",\n      \"@type\": \"ItemList\",\n      name: \"Din Lee Engineering Services\",\n      itemListElement: SERVICES.map((service, index) => ({\n        \"@type\": \"ListItem\",\n        position: index + 1,\n        name: service.title,\n        url: `${SITE.domain}/services/${service.slug}`,\n      })),\n    };\n\n    const breadcrumb = {\n      \"@context\": \"https://schema.org\",\n      \"@type\": \"BreadcrumbList\",\n      itemListElement: [\n        { \"@type\": \"ListItem\", position: 1, name: \"Home\", item: SITE.domain },\n        { \"@type\": \"ListItem\", position: 2, name: \"Services\", item: PAGE_URL },\n      ],\n    };\n\n    const webPage = {\n      \"@context\": \"https://schema.org\",\n      \"@type\": \"WebPage\",\n      name: \"Services\",\n      url: PAGE_URL,\n      description: SEO_DESC,\n      isPartOf: { \"@type\": \"WebSite\", name: SITE.brand, url: SITE.domain },\n    };\n\n    const localBusiness = {\n      \"@context\": \"https://schema.org\",\n      \"@type\": \"LocalBusiness\",\n      name: SITE.brand,\n      url: SITE.domain,\n      telephone: SITE.phone,\n      email: SITE.emailPrimary,\n      address: {\n        \"@type\": \"PostalAddress\",\n        streetAddress: SITE.addressLine,\n        addressLocality: \"Singapore\",\n        postalCode: \"757700\",\n        addressCountry: \"SG\",\n      },\n      areaServed: \"Singapore\",\n      geo: {\n        \"@type\": \"GeoCoordinates\",\n        latitude: SITE.geo.lat,\n        longitude: SITE.geo.lng,\n      },\n      openingHoursSpecification: [\n        {\n          \"@type\": \"OpeningHoursSpecification\",\n          dayOfWeek: [\"Monday\", \"Tuesday\", \"Wednesday\", \"Thursday\", \"Friday\", \"Saturday\"],\n          opens: \"09:00\",\n          closes: \"18:00\",\n        },\n      ],\n    };\n\n    const faqSchema = {\n      \"@context\": \"https://schema.org\",\n      \"@type\": \"FAQPage\",\n      mainEntity: FAQ.map((item) => ({\n        \"@type\": \"Question\",\n        name: item.q,\n        acceptedAnswer: {\n          \"@type\": \"Answer\",\n          text: item.a,\n        },\n      })),\n    };\n\n    return [itemList, breadcrumb, webPage, localBusiness, faqSchema];\n  }, [FAQ, PAGE_URL, SEO_DESC]);\n\n  return (\n    <>\n      {schemas.map((obj, idx) => (\n        <script key={idx} type=\"application/ld+json\">\n          {JSON.stringify(obj)}\n        </script>\n      ))}\n\n      <section className=\"bg-gradient-to-b from-slate-50 to-white border-b\">\n        <div className=\"max-w-6xl mx-auto px-4 py-12 grid lg:grid-cols-2 gap-10 items-center\">\n          <div>\n            <h1 className=\"text-3xl md:text-4xl font-extrabold text-slate-900\">\n              Awnings, Roofing, Shelter & Outdoor Systems in Singapore\n            </h1>\n\n            <p className=\"mt-4 text-slate-600 leading-relaxed\">\n              <span className=\"font-semibold text-slate-900\">{SITE.brand}</span> provides\n              practical, site-based solutions for <span className=\"font-semibold text-slate-900\">retractable awning Singapore</span>,{\" \"}\n              <span className=\"font-semibold text-slate-900\">polycarbonate roof Singapore</span>,{\" \"}\n              <span className=\"font-semibold text-slate-900\">glass canopy Singapore</span> and{\" \"}\n              <span className=\"font-semibold text-slate-900\">outdoor zip track Singapore</span>.\n              We handle measurement, fabrication, installation and after-sales support.\n            </p>\n\n            <div className=\"mt-6 rounded-2xl border border-slate-200 bg-white p-5\">\n              <h2 className=\"text-base font-extrabold text-slate-900\">Why Choose Din Lee Engineering</h2>\n              <ul className=\"mt-3 space-y-2 text-sm text-slate-600\">\n                {CONTENT.trustBullets.map((item) => (\n                  <li key={item} className=\"flex gap-2\">\n                    <span className=\"mt-[2px] text-emerald-600\">+</span>\n                    <span>{item}</span>\n                  </li>\n                ))}\n              </ul>\n            </div>\n\n            <div className=\"mt-6 flex gap-3 flex-wrap\">\n              <Link\n                to=\"/contact\"\n                className=\"px-5 py-3 rounded-xl bg-blue-600 text-white font-semibold hover:bg-blue-700 transition\"\n              >\n                Request a Quote\n              </Link>\n              <a\n                href={`tel:${SITE.phone}`}\n                className=\"px-5 py-3 rounded-xl bg-slate-900 text-white font-semibold hover:bg-slate-800 transition\"\n              >\n                Call Now\n              </a>\n            </div>\n\n            <div className=\"mt-4 text-sm text-slate-600\">\n              <span className=\"font-semibold text-slate-900\">Fast Quote:</span> Send postcode, photos and rough size on WhatsApp.\n            </div>\n          </div>\n\n          <div className=\"rounded-3xl overflow-hidden border bg-white shadow-sm\">\n            <img\n              src={IMAGES.hero}\n              alt=\"Din Lee Engineering awnings roofing shelter and zip track in Singapore\"\n              className=\"h-64 sm:h-80 w-full object-cover\"\n              loading=\"lazy\"\n              onError={(e) => {\n                e.currentTarget.src = IMAGES.fallback;\n              }}\n            />\n            <div className=\"p-5 border-t\">\n              <p className=\"text-sm text-slate-600 leading-relaxed\">\n                We focus on stable mounting, drainage planning, sealing and clean finishing so your outdoor structure performs better in Singapore weather.\n              </p>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      <section className=\"max-w-6xl mx-auto px-4 py-12\">\n        <div className=\"rounded-3xl border border-slate-200 bg-slate-50 p-6\">\n          <h2 className=\"text-2xl font-extrabold text-slate-900\">Singapore Service Guides</h2>\n          <p className=\"mt-2 max-w-3xl text-slate-600\">\n            These cluster pages target high-intent service keywords in Singapore and connect users to the most relevant service pages.\n          </p>\n          <div className=\"mt-6 grid md:grid-cols-2 lg:grid-cols-3 gap-4\">\n            {CLUSTERS.map((cluster) => (\n              <Link\n                key={cluster.slug}\n                to={`/services/${cluster.slug}`}\n                className=\"rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:shadow-lg\"\n              >\n                <div className=\"text-xs font-extrabold uppercase tracking-wide text-blue-600\">\n                  Cluster Page\n                </div>\n                <h3 className=\"mt-2 text-lg font-extrabold text-slate-900\">{cluster.title}</h3>\n                <p className=\"mt-2 text-sm leading-relaxed text-slate-600\">\n                  {cluster.seoDescription}\n                </p>\n                <div className=\"mt-4 text-sm font-bold text-blue-600\">Read guide</div>\n              </Link>\n            ))}\n          </div>\n        </div>\n\n        <div className=\"mt-12 flex items-end justify-between gap-4\">\n          <div>\n            <h2 className=\"text-2xl font-extrabold text-slate-900\">All Service Categories</h2>\n            <p className=\"mt-2 text-slate-600\">\n              Browse each service page for targeted details, FAQs and quotation guidance.\n            </p>\n          </div>\n        </div>\n\n        <div className=\"mt-8 grid sm:grid-cols-2 lg:grid-cols-3 gap-4\">\n          {SERVICES.map((service) => (\n            <div key={service.slug}>\n              <ServiceCard\n                title={service.title}\n                desc={service.desc}\n                href={`/services/${service.slug}`}\n                image={service.cardImage || service.heroImage || IMAGES.fallback}\n                alt={`${service.title} service in Singapore`}\n              />\n            </div>\n          ))}\n        </div>\n      </section>\n\n      <section className=\"bg-slate-50 border-t border-b\">\n        <div className=\"max-w-6xl mx-auto px-4 py-12\">\n          <div className=\"max-w-3xl\">\n            <h2 className=\"text-2xl font-extrabold text-slate-900\">How We Handle Site Work</h2>\n            <p className=\"mt-2 text-slate-600 leading-relaxed\">\n              Outdoor installations in Singapore need proper planning for fixing, support, drainage and finish. Our workflow is built to reduce common issues such as weak mounting, water ingress and poor alignment.\n            </p>\n          </div>\n\n          <div className=\"mt-6 rounded-2xl overflow-hidden border bg-white\">\n            <img\n              src={IMAGES.process}\n              alt=\"Site measurement, fabrication and installation process\"\n              className=\"h-56 sm:h-72 w-full object-cover\"\n              loading=\"lazy\"\n              onError={(e) => {\n                e.currentTarget.src = IMAGES.fallback;\n              }}\n            />\n          </div>\n\n          <div className=\"mt-8 grid md:grid-cols-2 gap-4\">\n            {CONTENT.processSteps.map((step) => (\n              <div key={step.h} className=\"rounded-2xl border border-slate-200 bg-white p-6\">\n                <h3 className=\"text-lg font-extrabold text-slate-900\">{step.h}</h3>\n                <p className=\"mt-2 text-slate-600 leading-relaxed\">{step.p}</p>\n              </div>\n            ))}\n          </div>\n        </div>\n      </section>\n\n      <section className=\"max-w-6xl mx-auto px-4 py-12 grid lg:grid-cols-3 gap-6\">\n        <div className=\"lg:col-span-2 space-y-4\">\n          {CONTENT.keywordSections.map((section) => (\n            <div key={section.h} className=\"rounded-2xl border border-slate-200 bg-white p-6\">\n              <h2 className=\"text-xl font-extrabold text-slate-900\">{section.h}</h2>\n              <p className=\"mt-2 text-slate-600 leading-relaxed\">{section.p}</p>\n            </div>\n          ))}\n\n          <div className=\"rounded-2xl overflow-hidden border bg-white\">\n            <img\n              src={IMAGES.materials}\n              alt=\"Materials for awnings roofing shelter and canopy systems\"\n              className=\"h-56 sm:h-72 w-full object-cover\"\n              loading=\"lazy\"\n              onError={(e) => {\n                e.currentTarget.src = IMAGES.fallback;\n              }}\n            />\n          </div>\n\n          {CONTENT.materials.map((item) => (\n            <div key={item.h} className=\"rounded-2xl border border-slate-200 bg-white p-6\">\n              <h2 className=\"text-xl font-extrabold text-slate-900\">{item.h}</h2>\n              <p className=\"mt-2 text-slate-600 leading-relaxed\">{item.p}</p>\n            </div>\n          ))}\n\n          {CONTENT.pricingFactors.map((block) => (\n            <div key={block.h} className=\"rounded-2xl border border-slate-200 bg-white p-6\">\n              <h2 className=\"text-xl font-extrabold text-slate-900\">{block.h}</h2>\n              <ul className=\"mt-3 space-y-2 text-slate-600\">\n                {block.items.map((item) => (\n                  <li key={item} className=\"flex gap-2\">\n                    <span className=\"mt-[2px] text-blue-600\">-</span>\n                    <span>{item}</span>\n                  </li>\n                ))}\n              </ul>\n            </div>\n          ))}\n        </div>\n\n        <aside className=\"lg:col-span-1 space-y-4\">\n          <div className=\"rounded-2xl border border-slate-200 bg-white p-6\">\n            <h3 className=\"text-lg font-extrabold text-slate-900\">Where Our Services Fit</h3>\n            <ul className=\"mt-3 space-y-2 text-slate-600\">\n              {CONTENT.useCases.map((item) => (\n                <li key={item} className=\"flex gap-2\">\n                  <span className=\"mt-[2px] text-emerald-600\">+</span>\n                  <span>{item}</span>\n                </li>\n              ))}\n            </ul>\n          </div>\n\n          {CONTENT.areas.map((area) => (\n            <div key={area.h} className=\"rounded-2xl border border-slate-200 bg-white p-6\">\n              <h3 className=\"text-lg font-extrabold text-slate-900\">{area.h}</h3>\n              <p className=\"mt-2 text-slate-600 leading-relaxed\">{area.p}</p>\n\n              <div className=\"mt-4 flex gap-3 flex-wrap\">\n                <a\n                  href={`tel:${SITE.phone}`}\n                  className=\"inline-block px-5 py-3 rounded-xl bg-slate-900 text-white font-semibold hover:bg-slate-800 transition\"\n                >\n                  Call {SITE.phone}\n                </a>\n                <Link\n                  to=\"/contact\"\n                  className=\"inline-block px-5 py-3 rounded-xl border border-slate-300 text-slate-900 font-semibold hover:bg-slate-50 transition\"\n                >\n                  Contact Form\n                </Link>\n              </div>\n            </div>\n          ))}\n        </aside>\n      </section>\n\n      <section className=\"bg-slate-50 border-t border-b\">\n        <div className=\"max-w-6xl mx-auto px-4 py-12\">\n          <div className=\"max-w-3xl\">\n            <h2 className=\"text-2xl font-extrabold text-slate-900\">{CONTENT.compare.h}</h2>\n            <p className=\"mt-2 text-slate-600 leading-relaxed\">\n              Good workmanship is not only about the final look. Proper support, slope planning, sealing and handover guidance help the finished work stay stable and practical.\n            </p>\n          </div>\n\n          <div className=\"mt-8 overflow-hidden rounded-2xl border bg-white\">\n            <div className=\"grid md:grid-cols-3 gap-0\">\n              <div className=\"p-4 text-sm font-bold text-slate-900 bg-slate-50 border-b md:border-b-0 md:border-r\">Item</div>\n              <div className=\"p-4 text-sm font-bold text-slate-900 bg-slate-50 border-b md:border-b-0 md:border-r\">{SITE.brand}</div>\n              <div className=\"p-4 text-sm font-bold text-slate-900 bg-slate-50\">Typical</div>\n\n              {CONTENT.compare.rows.map((row) => (\n                <div key={row[0]} className=\"contents\">\n                  <div className=\"p-4 text-sm text-slate-700 border-t md:border-r\">{row[0]}</div>\n                  <div className=\"p-4 text-sm text-slate-700 border-t md:border-r\">{row[1]}</div>\n                  <div className=\"p-4 text-sm text-slate-700 border-t\">{row[2]}</div>\n                </div>\n              ))}\n            </div>\n          </div>\n        </div>\n      </section>\n\n      <section className=\"max-w-6xl mx-auto px-4 py-12\">\n        <div className=\"max-w-3xl\">\n          <h2 className=\"text-2xl font-extrabold text-slate-900\">Service FAQs in Singapore</h2>\n          <p className=\"mt-2 text-slate-600\">\n            These answers help users understand common questions before requesting a site survey or quotation.\n          </p>\n        </div>\n\n        <div className=\"mt-8 grid gap-3 max-w-3xl\">\n          {FAQ.map((item) => (\n            <details key={item.q} className=\"group rounded-2xl border border-slate-200 bg-white p-5\">\n              <summary className=\"cursor-pointer list-none font-bold text-slate-900 flex items-center justify-between\">\n                <span>{item.q}</span>\n                <span className=\"text-slate-400 group-open:rotate-180 transition\">v</span>\n              </summary>\n              <p className=\"mt-3 text-sm text-slate-600 leading-relaxed\">{item.a}</p>\n            </details>\n          ))}\n        </div>\n      </section>\n\n      <section className=\"bg-slate-900\">\n        <div className=\"max-w-6xl mx-auto px-4 py-12 text-white grid md:grid-cols-2 gap-6 items-center\">\n          <div>\n            <h3 className=\"text-2xl font-extrabold\">Need Fast Quotation?</h3>\n            <p className=\"text-white/80 mt-2\">\n              Send postcode, photos, approximate size and your preferred awning or roof type. We will suggest practical options for your site.\n            </p>\n          </div>\n\n          <div className=\"md:justify-self-end w-full md:w-[360px] rounded-2xl overflow-hidden border border-white/15 bg-white/5\">\n            <img\n              src={IMAGES.quote}\n              alt=\"Quotation support for awnings roofing shelter and zip track in Singapore\"\n              className=\"h-40 w-full object-cover\"\n              loading=\"lazy\"\n              onError={(e) => {\n                e.currentTarget.src = IMAGES.fallback;\n              }}\n            />\n          </div>\n\n          <div className=\"md:text-right flex md:justify-end gap-3 flex-wrap md:col-span-2\">\n            <a\n              href={`tel: