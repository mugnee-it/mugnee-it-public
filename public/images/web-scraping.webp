  const SEO_DESC = "Din Lee Engineering provides retractable awnings, rooftop awnings, loop awnings, shelters, glass canopy, ACP and polycarbonate roofing, outdoor zip track, roller blinds, metal works, decking and renovation support in Singapore.";
  const IMAGES = useMemo(() => ({
