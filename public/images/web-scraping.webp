}"9␀␀{"version":3,"sources":["webpack://../../../../Last%20Update/Dinlee%20Engineering%20Pte.%20Ltd/Dinlee%20Engineering%20Pte.%20Ltd/dinleeengineering/src/pages/Projects.jsx"],"names":["useMemo","useState","SITE","Link","usePageSeo","jsxDEV","_jsxDEV","Fragment","_Fragment","PROJECTS","title","tag","note","img","Projects","_s","PAGE_URL","domain","SEO_TITLE","SEO_DESC","description","canonicalUrl","ogImage","tags","Array","from","Set","map","p","active","setActive","filtered","filter","children","className","fileName","_jsxFileName","lineNumber","columnNumber","t","onClick","src","alt","loading","href","phone","to","_c","$RefreshReg$"],"mappings":";;;;AAAA;AACA,SAASA,OAAO,EAAEC,QAAQ,QAAQ,OAAO;AACzC,SAASC,IAAI,QAAQ,cAAc;AACnC,SAASC,IAAI,QAAQ,kBAAkB;AACvC,OAAOC,UAAU,MAAM,qBAAqB;;AAE5C;AAAA,SAAAC,MAAA,IAAAC,OAAA,EAAAC,QAAA,IAAAC,SAAA;AACA,MAAMC,QAAQ,GAAG,CACf;EACEC,KAAK,EAAE,iCAAiC;EACxCC,GAAG,EAAE,QAAQ;EACbC,IAAI,EAAE,oCAAoC;EAC1CC,GAAG,EAAE;AACP,CAAC,EACD;EACEH,KAAK,EAAE,yBAAyB;EAChCC,GAAG,EAAE,QAAQ;EACbC,IAAI,EAAE,6BAA6B;EACnCC,GAAG,EAAE;AACP,CAAC,EACD;EACEH,KAAK,EAAE,oCAAoC;EAC3CC,GAAG,EAAE,SAAS;EACdC,IAAI,EAAE,wBAAwB;EAC9BC,GAAG,EAAE;AACP,CAAC,EACD;EACEH,KAAK,EAAE,sBAAsB;EAC7BC,GAAG,EAAE,SAAS;EACdC,IAAI,EAAE,yBAAyB;EAC/BC,GAAG,EAAE;AACP,CAAC,EACD;EACEH,KAAK,EAAE,0BAA0B;EACjCC,GAAG,EAAE,WAAW;EAChBC,IAAI,EAAE,2BAA2B;EACjCC,GAAG,EAAE;AACP,CAAC,EACD;EACEH,KAAK,EAAE,kCAAkC;EACzCC,GAAG,EAAE,UAAU;EACfC,IAAI,EAAE,wBAAwB;EAC9BC,GAAG,EAAE;AACP,CAAC,EACD;EACEH,KAAK,EAAE,gCAAgC;EACvCC,GAAG,EAAE,SAAS;EACdC,IAAI,EAAE,0BAA0B;EAChCC,GAAG,EAAE;AACP,CAAC,EACD;EACEH,KAAK,EAAE,mBAAmB;EAC1BC,GAAG,EAAE,SAAS;EACdC,IAAI,EAAE,8BAA8B;EACpCC,GAAG,EAAE;AACP,CAAC,EACD;EACEH,KAAK,EAAE,0BAA0B;EACjCC,GAAG,EAAE,YAAY;EACjBC,IAAI,EAAE,wBAAwB;EAC9BC,GAAG,EAAE;AACP,CAAC,EACD;EACEH,KAAK,EAAE,qBAAqB;EAC5BC,GAAG,EAAE,QAAQ;EACbC,IAAI,EAAE,2BAA2B;EACjCC,GAAG,EAAE;AACP,CAAC,CACF;AAED,eAAe,SAASC,QAAQA,CAAA,EAAG;EAAAC,EAAA;EACjC,MAAMC,QAAQ,GAAG,GAAGd,IAAI,CAACe,MAAM,WAAW;EAE1C,MAAMC,SAAS,GACb,wEAAwE;EAC1E,