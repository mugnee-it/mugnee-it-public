C,UAAA;cAAAC,YAAA;YAAA,OACf;UAAC;YAAAH,QAAA,EAAAC,YAAA;YAAAC,UAAA;YAAAC,YAAA;UAAA,OACC,CAAC,eAGNhC,OAAA;YAAK4B,SAAS,EAAC,KAAK;YAAAD,QAAA,gBAClB3B,OAAA;cAAK4B,SAAS,EAAC,+CAA+C;cAAAD,QAAA,EAC3DL,CAAC,CAACjB;YAAG;cAAAwB,QAAA,EAAAC,YAAA;cAAAC,UAAA;cAAAC,YAAA;YAAA,OACH,CAAC,eACNhC,OAAA;cAAI4B,SAAS,EAAC,4CAA4C;cAAAD,QAAA,EACvDL,CAAC,CAAClB;YAAK;cAAAyB,QAAA,EAAAC,YAAA;cAAAC,UAAA;cAAAC,YAAA;YAAA,OACN,CAAC,eACLhC,OAAA;cAAG4B,SAAS,EAAC,6BAA6B;cAAAD,QAAA,EACvCL,CAAC,CAAChB;YAAI;cAAAuB,QAAA,EAAAC,YAAA;cAAAC,UAAA;cAAAC,YAAA;YAAA,OACN,CAAC;UAAA;YAAAH,QAAA,EAAAC,YAAA;YAAAC,UAAA;YAAAC,YAAA;UAAA,OACD,CAAC;QAAA,GAxBDV,CAAC,CAAClB,KAAK;UAAAyB,QAAA,EAAAC,YAAA;UAAAC,UAAA;UAAAC,YAAA;QAAA,OAyBT,CACN;MAAC;QAAAH,QAAA,EAAAC,YAAA;QAAAC,UAAA;QAAAC,YAAA;MAAA,OACC,CAAC;IAAA;MAAAH,QAAA,EAAAC,YAAA;MAAAC,UAAA;MAAAC,YAAA;IAAA,OACC,CAAC,eAGVhC,OAAA;MAAS4B,SAAS,EAAC,sBAAsB;MAAAD,QAAA,eACvC3B,OAAA;QAAK4B,SAAS,EAAC,8BAA8B;QAAAD,QAAA,gBAC3C3B,OAAA;UAAI4B,SAAS,EAAC,wCAAwC;UAAAD,QAAA,EAAC;QAEvD;UAAAE,QAAA,EAAAC,YAAA;UAAAC,UAAA;UAAAC,YAAA;QAAA,OAAI,CAAC,eACLhC,OAAA;UAAG4B,SAAS,EAAC,+BAA+B;UAAAD,QAAA,EAAC;QAM7C;UAAAE,QAAA,EAAAC,YAAA;UAAAC,UAAA;UAAAC,YAAA;QAAA,OAAG,CAAC;MAAA;QAAAH,QAAA,EAAAC,YAAA;QAAAC,UAAA;QAAAC,YAAA;MAAA,OACD;IAAC;MAAAH,QAAA,EAAAC,YAAA;MAAAC,UAAA;MAAAC,YAAA;IAAA,OACC,CAAC,eAGVhC,OAAA;MAAS4B,SAAS,EAAC,cAAc;MAAAD,QAAA,eAC/B3B,OAAA;QAAK4B,SAAS,EAAC,gFAAgF;QAAAD,QAAA,gBAC7F3B,OAAA;UAAA2B,QAAA,gBACE3B,OAAA;YAAI4B,SAAS,EAAC,yBAAyB;YAAAD,QAAA,EAAC;UAExC;YAAAE,QAAA,EAAAC,YAAA;YAAAC,UAAA;YAAAC,YAAA;UAAA,OAAI,CAAC,eACLhC,OAAA;YAAG4B,SAAS,EAAC,oBAAoB;YAAAD,QAAA,EAAC;UAGlC;YAAAE,QAAA,EAAAC,YAAA;YAAAC,UAAA;YAAAC,YAAA;UAAA,OAAG,CAAC;QAAA;UAAAH,QAAA,EAAAC,YAAA;UAAAC,UAAA;UAAAC,YAAA;QAAA,OACD,CAAC,eACNhC,OAAA;UAAK4B,SAAS,EAAC,mDAAmD;UAAAD,QAAA,gBAChE3B,OAAA;YACEsC,IAAI,EAAE,OAAO1C,IAAI,CAAC2C,KAAK,EAAG;YAC1BX,SAAS,EAAC,mGAAmG;YAAAD,QAAA,GAC9G,OACM,EAAC/B,IAAI,CAAC2C,KAAK;UAAA;YAAAV,QAAA,EAAAC,YAAA;YAAAC,UAAA;YAAAC,YAAA;UAAA,OACf,CAAC,eACJhC,OAAA,CAACH,IAAI;YACH2C,EAAE,EAAC,UAAU;YACbZ,SAAS,EAAC,4GAA4G;YAAAD,QAAA,EACvH;UAED;YAAAE,QAAA,EAAAC,YAAA;YAAAC,UAAA;YAAAC,YAAA;UAAA,OAAM,CAAC;QAAA;UAAAH,QAAA,EAAAC,YAAA;UAAAC,UAAA;UAAAC,YAAA;QAAA,OACJ,CAAC;MAAA;QAAAH,QAAA,EAAAC,YAAA;QAAAC,UAAA;QAAAC,YAAA;MAAA,OACH;IAAC;MAAAH,QAAA,EAAAC,YAAA;MAAAC,UAAA;MAAAC,YAAA;IAAA,OACC,CAAC;EAAA,eACV,CAAC;AAEP;AAACvB,EAAA,CAnJuBD,QAAQ;EAAA,QAQ9BV,UAAU;AAAA;AAAA2C,EAAA,GARYjC,QAAQ;AAAA,IAAAiC,EAAA;AAAAC,YAAA,CAAAD,EAAA,c","sourcesContent":["// src/pages/Projects.jsx\nimport { useMemo, useState } from \"react\";\nimport { SITE } from \"../data/site\";\nimport { Link } from \"react-router-dom\";\nimport usePageSeo from \"../hooks/usePageSeo\";\n\r\n/* ================= PROJECT DATA (10 PROJECTS) ================= */\r\nconst PROJECTS = [\r\n  {\r\n    title: \"Retractable Awning Installation\",\r\n    tag: \"Awning\",\r\n    note: \"Residential & Commercial Buildings\",\r\n    img: \"/images/Retractable-Awning.png\",\r\n  },\r\n  {\r\n    title: \"Motorised Awning System\",\r\n    tag: \"Awning\",\r\n    note: \"Cafe & Outdoor Seating Area\",\r\n    img: \"/images/Motorised-Awning-System.png\",\r\n  },\r\n  {\r\n    title: \"Polycarbonate Roofing Installation\",\r\n    tag: \"Roofing\",\r\n    note: \"Car Porch & Patio Area\",\r\n    img: \"/images/Polycarbonate-Roofing-Installation.png\",\r\n  },\r\n  {\r\n    title: \"Glass Canopy Shelter\",\r\n    tag: \"Shelter\",\r\n    note: \"Walkway & Main Entrance\",\r\n    img: \"/images/Glass-Canopy-Shelter-.png\",\r\n  },\r\n  {\r\n    title: \"Outdoor Zip Track System\",\r\n    tag: \"Zip Track\",\r\n    note: \"Balcony & Patio Enclosure\",\r\n    img: \"/images/Outdoor-Zip-Track-System.png\",\r\n  },\r\n  {\r\n    title: \"ACP Roofing with Metal Structure\",\r\n    tag: \"ACP Roof\",\r\n    note: \"Outdoor Extension Area\",\r\n    img: \"/images/ACP-Roofing-with-Metal-Structure.png\",\r\n  },\r\n  {\r\n    title: \"Aluminium Louvers Installation\",\r\n    tag: \"Roofing\",\r\n    note: \"Modern Residential House\",\r\n    img: \"/images/Aluminium-Louvers-Installation.png\",\r\n  },\r\n  {\r\n    title: \"Glass Roof Canopy\",\r\n    tag: \"Shelter\",\r\n    note: \"Commercial Building Entrance\",\r\n    img: \"/images/Glass-Roof-Canopy.png\",\r\n  },\r\n  {\r\n    title: \"Wooden Decking & Pergola\",\r\n    tag: \"Renovation\",\r\n    note: \"Garden & Backyard Area\",\r\n    img: \"/images/Wooden-Decking-Pergola.png\",\r\n  },\r\n  {\r\n    title: \"Custom Metal Awning\",\r\n    tag: \"Awning\",\r\n    note: \"Industrial & Factory Area\",\r\n    img: \"/images/Custom-Metal-Awning.png\",\r\n  },\r\n];\r\n\r\nexport default function Projects() {\r\n  const PAGE_URL = `${SITE.domain}/projects`;\r\n\r\n  const SEO_TITLE =\n    \"Completed Projects | Awning, Roofing, Shelter & Zip Track in Singapore\";\n  const SEO_DESC =\n    \"Explore completed awning, roofing, shelter, zip track and outdoor renovation projects by Din Lee Engineering in Singapore.\";\n\n  usePageSeo({\n    title: SEO_TITLE,\n    description: SEO_DESC,\n    canonicalUrl: PAGE_URL,\n    ogImage: `${SITE.domain}/images/ACP-Roofing-with-Metal-Structure.png`,\n  });\n\r\n  /* ================= FILTER ================= */\r\n  const tags = useMemo(\r\n    () => [\"All\", ...Array.from(new Set(PROJECTS.map((p) => p.tag)))],\r\n    []\r\n  );\r\n  const [active, setActive] = useState(\"All\");\r\n\r\n  const filtered = useMemo(() => {\r\n    if (active === \"All\") return PROJECTS;\r\n    return PROJECTS.filter((p) => p.tag === active);\r\n  }, [active]);\r\n\r\n  return (\n    <>\r\n      {/* ================= HERO / H1 ================= */}\r\n      <section className=\"bg-gradient-to-b from-slate-50 to-white border-b\">\r\n        <div className=\"max-w-6xl mx-auto px-4 py-12\">\r\n          <h1 className=\"text-3xl md:text-4xl font-extrabold text-slate-900\">\r\n            Completed Awning, Roofing & Shelter Projects in Singapore\r\n          </h1>\r\n\r\n          <p className=\"mt-4 max-w-3xl text-slate-600\">\r\n            Din Lee Engineering has successfully completed numerous awning,\r\n            roofing, glass canopy, zip track and outdoor renovation projects\r\n            across Singapore. Below are selected projects showcasing our\r\n            workmanship, materials and installation quality.\r\n          </p>\r\n\r\n          {/* Filter */}\r\n          <div className=\"mt-6 flex flex-wrap gap-2\">\r\n            {tags.map((t) => (\r\n              <button\r\n                key={t}\r\n                onClick={() => setActive(t)}\r\n                className={`px-4 py-2 rounded-full text-sm font-semibold border transition ${\r\n                  active === t\r\n                    ? \"bg-blue-600 text-white border-blue-600\"\r\n                    : \"bg-white text-slate-700 hover:bg-slate-50\"\r\n                }`}\r\n              >\r\n                {t}\r\n              </button>\r\n            ))}\r\n          </div>\r\n        </div>\r\n      </section>\r\n\r\n      {/* ================= PROJECT GRID ================= */}\r\n      <section className=\"max-w-6xl mx-auto px-4 py-14\">\r\n        <h2 className=\"sr-only\">\r\n          Awning, Roofing, Shelter and Zip Track Project Gallery\r\n        </h2>\r\n\r\n        <div className=\"grid sm:grid-cols-2 lg:grid-cols-3 gap-6\">\r\n          {filtered.map((p) => (\r\n            <div\r\n              key={p.title}\r\n              className=\"rounded-3xl border bg-white overflow-hidden shadow-sm hover:shadow-lg transition\"\r\n            >\r\n              {/* Image (FIXED HEIGHT ISSUE) */}\r\n              <div className=\"aspect-[4/3] bg-slate-100 overflow-hidden\">\r\n                <img\r\n                  src={p.img}\r\n                  alt={`${p.title} project in Singapore`}\r\n                  className=\"h-full w-full object-cover hover:scale-105 transition duration-500\"\r\n                  loading=\"lazy\"\r\n                />\r\n              </div>\r\n\r\n              {/* Content */}\r\n              <div className=\"p-5\">\r\n                <div className=\"text-xs font-semibold text-blue-600 uppercase\">\r\n                  {p.tag}\r\n                </div>\r\n                <h3 className=\"mt-2 text-lg font-extrabold text-slate-900\">\r\n                  {p.title}\r\n                </h3>\r\n                <p className=\"mt-2 text-sm text-slate-600\">\r\n                  {p.note}\r\n                </p>\r\n              </div>\r\n            </div>\r\n          ))}\r\n        </div>\r\n      </section>\r\n\r\n      {/* ================= SEO CONTENT ================= */}\r\n      <section className=\"bg-slate-50 border-t\">\r\n        <div className=\"max-w-6xl mx-auto px-4 py-14\">\r\n          <h2 className=\"text-2xl font-extrabold text-slate-900\">\r\n            Trusted Awning & Roofing Contractor in Singapore\r\n          </h2>\r\n          <p className=\"mt-4 max-w-4xl text-slate-600\">\r\n            We specialise in custom awnings, polycarbonate roofing, glass\r\n            canopy shelters, outdoor zip track systems and metal works for\r\n            residential, commercial and industrial properties. From site\r\n            measurement to fabrication and installation, every project is\r\n            handled by our experienced in-house team.\r\n          </p>\r\n        </div>\r\n      </section>\r\n\r\n      {/* ================= CTA ================= */}\r\n      <section className=\"bg-slate-900\">\r\n        <div className=\"max-w-6xl mx-auto px-4 py-12 text-white grid md:grid-cols-2 gap-6 items-center\">\r\n          <div>\r\n            <h2 className=\"text-2xl font-extrabold\">\r\n              Planning a Similar Project?\r\n            </h2>\r\n            <p className=\"text-white/80 mt-2\">\r\n              Contact us with your site location, size and requirement. We will\r\n              recommend the best awning or roofing solution for you.\r\n            </p>\r\n          </div>\r\n          <div className=\"md:text-right flex md:justify-end gap-3 flex-wrap\">\r\n            <a\r\n              href={`tel:${SITE.phone}`}\r\n              className=\"inline-block px-6 py-3 rounded-xl bg-white text-slate-900 font-bold hover:bg-slate-100 transition\"\r\n            >\r\n              Call {SITE.phone}\r\n            </a>\r\n            <Link\r\n              to=\"/contact\"\r\n              className=\"inline-block px-6 py-3 rounded-xl border border-white/30 text-white font-bold hover:bg-white/10 transition\"\r\n            >\r\n              Contact Form\r\n            </Link>\r\n          </div>\r\n        </div>\r\n      </section>\r\n    </>\r\n  );\r\n}\r\n"],"file":"x"}␀␀false018__webpack_require__4046__webpack_require__48175/*! ./node_modules/react-refresh/runtime.js */ "./node_modules/react-refresh/runtime.js"328339__webpack_require__.$Refresh$.signature3704114134484504894915356076872157217122242227_data_site__WEBPACK_IMPORTED_MODULE_1__.SITE24892498(0,_hooks_usePageSeo__WEBPACK_IMPORTED_MODULE_3__["default"])25952598_data_site__WEBPACK_IMPORTED_MODULE_1__.SITE27262732(0,react__WEBPACK_IMPORTED_MODULE_0__.useMemo)28342841(0,react__WEBPACK_IMPORTED_MODULE_0__.useState)28702876(0,react__WEBPACK_IMPORTED_MODULE_0__.useMemo)30183024(0,react_jsx_dev_runtime__WEBPACK_IMPORTED_MODULE_4__.jsxDEV)30263034react_jsx_dev_runtime__WEBPACK_IMPORTED_MODULE_4__.Fragment30673073(0,react_jsx_dev_runtime__WEBPACK_IMPORTED_MODULE_4__.jsxDEV)31863192(0,react_jsx_dev_runtime__WEBPACK_IMPORTED_MODULE_4__.jsxDEV)32863292(0,react_jsx_dev_runtime__WEBPACK_IMPORTED_MODULE_4__.jsxDEV)36043610(0,react_jsx_dev_runtime__WEBPACK_IMPORTED_MODULE_4__.jsxDEV)40814087(0,react_jsx_dev_runtime__WEBPACK_IMPORTED_MODULE_4__.jsxDEV)41954201(0,react_jsx_dev_runtime__WEBPACK_IMPORTED_MODULE_4__.jsxDEV)49945000(0,react_jsx_dev_runtime__WEBPACK_IMPORTED_MODULE_4__.jsxDEV)50945100(0,react_jsx_dev_runtime__WEBPACK_IMPORTED_MODULE_4__.jsxDEV)53515357(0,react_jsx_dev_runtime__WEBPACK_IMPORTED_MODULE_4__.jsxDEV)54805486(0,react_jsx_dev_runtime__WEBPACK_IM