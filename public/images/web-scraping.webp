awning singapore\",\n    secondary: [\"roof terrace shade\", \"rooftop shelter\", \"rooftop canopy contractor\"],\n    useCases: [\"roof terrace seating\", \"open rooftop utility zone\", \"sun and rain coverage\"],\n    materials: [\"heavy-duty support structure\", \"weather-resistant roof panel\", \"anchoring hardware\"],\n    priceDrivers: [\"wind exposure\", \"roof access\", \"structure span\", \"site safety requirements\"],\n  },\n  \"glass-canopy\": {\n    primary: \"glass canopy singapore\",\n    secondary: [\"entrance glass canopy\", \"walkway canopy\", \"safety glass shelter\"],\n    useCases: [\"building entrance\", \"front facade shelter\", \"covered walkway\"],\n    materials: [\"laminated or tempered glass\", \"metal support frame\", \"waterproof edge detailing\"],\n    priceDrivers: [\"glass thickness\", \"projection depth\", \"support design\", \"installation access\"],\n  },\n  sunshade: {\n    primary: \"sunshade singapore\",\n    secondary: [\"outdoor shade solution\", \"heat reduction shade\", \"patio shade installer\"],\n    useCases: [\"balcony heat control\", \"outdoor waiting area\", \"west-facing opening\"],\n    materials: [\"shade fabric\", \"aluminum support\", \"customized fixing system\"],\n    priceDrivers: [\"coverage area\", \"fabric type\", \"frame type\", \"site condition\"],\n  },\n  \"outdoor-zip-track\": {\n    primary: \"outdoor zip track singapore\",\n    secondary: [\"balcony zip track\", \"zip blind system\", \"patio weather blind\"],\n    useCases: [\"balcony enclosure\", \"patio side rain control\", \"privacy upgrade\"],\n    materials: [\"zip guide track\", \"outdoor screen fabric\", \"manual/motorized control\"],\n    priceDrivers: [\"opening width\", \"control option\", \"track layout\", \"mounting surface\"],\n  },\n  \"roller-blind\": {\n    primary: \"outdoor roller blind singapore\",\n    secondary: [\"balcony roller blind\", \"sun control blind\", \"privacy blind installer\"],\n    useCases: [\"glare reduction\", \"afternoon sun control\", \"semi-open balcony privacy\"],\n    materials: [\"outdoor blind fabric\", \"rolling tube system\", \"mounting bracket set\"],\n    priceDrivers: [\"fabric openness\", \"blind size\", \"mechanism type\", \"installation points\"],\n  },\n  \"acp-roof\": {\n    primary: \"acp roof singapore\",\n    secondary: [\"aluminium composite panel roofing\", \"acp roof contractor\", \"outdoor roof extension\"],\n    useCases: [\"patio roof extension\", \"walkway roof\", \"modern facade coverage\"],\n    materials: [\"ACP panel\", \"structural frame\", \"waterproof sealing detail\"],\n    priceDrivers: [\"panel area\", \"frame complexity\", \"drainage detail\", \"site access\"],\n  },\n  \"polycarbonate-roof\": {\n    primary: \"polycarbonate roof singapore\",\n    secondary: [\"car porch polycarbonate roof\", \"patio roofing\", \"clear roof panel\"],\n    useCases: [\"car porch coverage\", \"patio shelter\", \"side walkway protection\"],\n    materials: [\"polycarbonate sheet\", \"aluminum or metal frame\", \"joint and edge seal\"],\n    priceDrivers: [\"sheet thickness\", \"span size\", \"tint choice\", \"structural support\"],\n  },\n  \"aluminium-fluted-roof\": {\n    primary: \"aluminium fluted roof singapore\",\n    secondary: [\"fluted roof panel\", \"modern outdoor roof\", \"premium roof installation\"],\n    useCases: [\"premium patio finish\", \"architectural facade roof\", \"modern extension\"],\n    materials: [\"fluted aluminum panel\", \"custom frame support\", \"precision edge finishing\"],\n    priceDrivers: [\"panel profile\", \"design complexity\", \"span and support\", \"finishing quality\"],\n  },\n  \"zinc-roof\": {\n    primary: \"zinc roof singapore\",\n    secondary: [\"zinc roofing contractor\", \"corrugated roof\", \"utility roof cover\"],\n    useCases: [\"utility area roofing\", \"industrial side cover\", \"functional outdoor shelter\"],\n    materials: [\"zinc roofing sheet\", \"support purlin\", \"water run-off detail\"],\n    priceDrivers: [\"sheet profile\", \"structure size\", \"mounting condition\", \"replacement scope\"],\n  },\n  \"pvc-ceiling\": {\n    primary: \"wood grain ceiling singapore\",\n    secondary: [\"pvc ceiling singapore\", \"outdoor ceiling panel\", \"easy maintenance ceiling\"],\n    useCases: [\"covered patio ceiling\", \"balcony false ceiling\", \"feature ceiling upgrade\"],\n    materials: [\"wood grain panel\", \"ceiling frame\", \"edge trim and finishing\"],\n    priceDrivers: [\"ceiling area\", \"panel type\", \"frame condition\", \"detailing work\"],\n  },\n  \"aluminum-ceiling\": {\n    primary: \"aluminum ceiling singapore\",\n    secondary: [\"false ceiling singapore\", \"metal ceiling panel\", \"ceiling contractor\"],\n    useCases: [\"commercial ceiling\", \"residential covered zone\", \"serviceable false ceiling\"],\n    materials: [\"aluminum panel\", \"suspension frame\", \"joint and trim accessories\"],\n    priceDrivers: [\"layout design\", \"ceiling size\", \"panel grade\", \"service opening requirements\"],\n  },\n  \"metal-work\": {\n    primary: \"metal work singapore\",\n    secondary: [\"custom metal fabrication\", \"steel frame contractor\", \"welding services\"],\n    useCases: [\"custom support frame\", \"awning brackets\", \"structure reinforcement\"],\n    materials: [\"mild steel/aluminum sections\", \"custom plate and bracket\", \"protective coating\"],\n    priceDrivers: [\"fabrication complexity\", \"material grade\", \"welding and finishing\", \"on-site fitment\"],\n  },\n  \"wooden-trellis\": {\n    primary: \"wooden trellis singapore\",\n    secondary: [\"outdoor trellis installer\", \"garden trellis\", \"patio trellis\"],\n    useCases: [\"garden feature structure\", \"patio decorative shade\", \"landscape enhancement\"],\n    materials: [\"treated wood\", \"support post\", \"protective finishing coat\"],\n    priceDrivers: [\"trellis size\", \"wood type\", \"design pattern\", \"site anchoring\"],\n  },\n  \"wooden-decking\": {\n    primary: \"wooden decking singapore\",\n    secondary: [\"outdoor decking installer\", \"patio deck flooring\", \"garden deck\"],\n    useCases: [\"outdoor lounge deck\", \"garden pathway deck\", \"patio floor upgrade\"],\n    materials: [\"decking board\", \"sub-frame joist\", \"surface protection treatment\"],\n    priceDrivers: [\"deck area\", \"board type\", \"sub-frame condition\", \"edge finishing\"],\n  },\n  renovation: {\n    primary: \"renovation contractor singapore\",\n    secondary: [\"general contractor singapore\", \"outdoor renovation\", \"project coordination\"],\n    useCases: [\"multi-scope outdoor upgrade\", \"structure and finishing coordination\", \"combined roof and ceiling works\"],\n    materials: [\"scope-dependent material mix\", \"site-specific structure\", \"finishing and sealing set\"],\n    priceDrivers: [\"scope count\", \"project timeline\", \"site constraints\", \"coordination complexity\"],\n  },\n};\n\nfunction getProfile(service) {\n  const fallback = {\n    primary: `${service.title.toLowerCase()} singapore`,\n    secondary: [\"outdoor contractor singapore\", \"custom installation\", \"site measurement and installation\"],\n    useCases: [\"residential project\", \"commercial project\", \"industrial project\"],\n    materials: [\"site-appropriate material\", \"support structure\", \"weather-resistant finishing\"],\n    priceDrivers: [\"size\", \"materials\", \"installation access\", \"design complexity\"],\n  };\n  return SERVICE_PROFILE[service.slug] || fallback;\n}\n\nfunction buildIntro(service, profile) {\n  return `${SITE.brand} provides ${service.title.toLowerCase()} solutions in Singapore with proper site survey, material planning, fabrication and installation. This page is written for users searching \"${profile.primary}\" and related terms, so you can compare options, understand pricing factors, and choose a suitable system for your property.`;\n}\n\nfunction buildSections(service, profile) {\n  return [\n    {\n      h: `Why Choose ${service.title} for Singapore Conditions`,\n      p: `${service.title} is commonly selected in Singapore where strong sun exposure, sudden rain and practical maintenance matter. We recommend a solution based on your site orientation, opening size and daily use pattern so the final system is durable and functional.`,\n    },\n    {\n      h: \"Best-Fit Use Cases\",\n      p: `Typical applications include ${profile.useCases.join(\", \")}. During survey, we check how your space is used at different times of day, then propose a suitable structure and coverage depth.`,\n    },\n    {\n      h: \"Material and System Options\",\n      p: `Common material components include ${profile.materials.join(\", \")}. The right combination depends on required lifespan, visual style and budget. We explain trade-offs clearly before fabrication starts.`,\n    },\n    {\n      h: \"Process: Survey to Installation\",\n      p: `Our standard workflow is site measurement, technical recommendation, quotation, fabrication, installation and finishing checks. This process reduces common issues such as weak fixing points, water ingress and uneven alignment.`,\n    },\n    {\n      h: \"What Affects Quotation\",\n      p: `Key price drivers are ${profile.priceDrivers.join(\", \")}. For a faster quotation, share your postcode, photos from two angles, and rough dimensions. We then provide practical options with estimated cost direction.`,\n    },\n    {\n      h: \"Service Coverage and Next Step\",\n      p: `We serve projects across Singapore for residential, commercial and industrial sites. If you need ${service.title.toLowerCase()} support, contact us for measurement scheduling and recommended solution planning.`,\n    },\n  ];\n}\n\nfunction buildFaqs(service, profile) {\n  return [\n    {\n      q: `Do you provide site measurement for ${service.title} in Singapore?`,\n      a: \"Yes. Site measurement is included before final proposal so structure, mounting and finishing can be planned correctly.\",\n    },\n    {\n      q: `How long does ${service.title.toLowerCase()} installation usually take?`,\n      a: \"Timeline depends on size, fabrication complexity and access conditions. Standard scopes are typically scheduled quickly after measurement confirmation.\",\n    },\n    {\n      q: \"How can I get a fast quote?\",\n      a: `Send location, photos and approximate dimensions by WhatsApp or call ${SITE.phone}. We will suggest options and estimated cost range.`,\n    },\n    {\n      q: `Which search terms does this page cover?`,\n      a: `This page targets ${profile.primary} and related searches such as ${profile.secondary.slice(0, 2).join(\" and \")} in a natural, user-focused way.`,\n    },\n    {\n      q: \"Do you support both residential and commercial projects?\",\n      a: \"Yes. We support residential, commercial and selected industrial projects based on site requirement.\",\n    },\n  ];\n}\n\nexport default function ServiceDetail() {\n  const { slug } = useParams();\n  const service = getServiceBySlug(slug);\n\n  const PAGE_URL = service ? serviceUrl(service.slug) : `${SITE.domain}/services`;\n  const SEO_TITLE = service ? service.seoTitle || `${service.title} Singapore | ${SITE.brand}` : `Service Not Found | ${SITE.brand}`;\n  const SEO_DESC = service\n    ? service.seoDesc || `${service.desc} Site measurement, fabrication and installation in Singapore. Call ${SITE.phone}.`\n    : `The requested service page was not found. View all services by ${SITE.brand}.`;\n\n  const profile = useMemo(() => (service ? getProfile(service) : null), [service]);\n  const intro = useMemo(() => (service && profile ? buildIntro(service, profile) : \"\"), [profile, service]);\n  const detailSections = useMemo(() => (service && profile ? buildSections(service, profile) : []), [profile, service]);\n  const detailFaqs = useMemo(() => (service && profile ? buildFaqs(service, profile) : []), [profile, service]);\n  const relatedServices = useMemo(\n    () => (service ? SERVICES.filter((s) => s.slug !== service.slug).slice(0, 6) : []),\n    [service]\n  );\n  const relatedClusters = useMemo(\n    () =>\n      CLUSTERS.filter((cluster) =>\n        (cluster.relatedServiceSlugs || []).includes(service?.slug)\n      ).slice(0, 4),\n    [service]\n  );\n\n  const schemas = useMemo(() => {\n    if (!service) return [];\n\n    const breadcrumb = {\n      \"@context\": \"https://schema.org\",\n      \"@type\": \"BreadcrumbList\",\n      itemListElement: [\n        { \"@type\": \"ListItem\", position: 1, name: \"Home\", item: SITE.domain },\n        { \"@type\": \"ListItem\", position: 2, name: \"Services\", item: `${SITE.domain}/services` },\n        { \"@type\": \"ListItem\", position: 3, name: service.title, item: PAGE_URL },\n      ],\n    };\n\n    const webPage = {\n      \"@context\": \"https://schema.org\",\n      \"@type\": \"WebPage\",\n      name: `${service.title} in Singapore`,\n      url: PAGE_URL,\n      description: SEO_DESC,\n    };\n\n    const serviceSchema = {\n      \"@context\": \"https://schema.org\",\n      \"@type\": \"Service\",\n      name: `${service.title} in Singapore`,\n      description: intro || service.desc,\n      areaServed: \"Singapore\",\n      url: PAGE_URL,\n      provider: {\n        \"@type\": \"LocalBusiness\",\n        name: SITE.brand,\n        telephone: SITE.phone,\n        email: SITE.emailPrimary,\n        address: {\n          \"@type\": \"PostalAddress\",\n          streetAddress: SITE.addressLine,\n          addressLocality: \"Singapore\",\n          postalCode: \"757700\",\n          addressCountry: \"SG\",\n        },\n      },\n    };\n\n    const faqSchema = {\n      \"@context\": \"https://schema.org\",\n      \"@type\": \"FAQPage\",\n      mainEntity: detailFaqs.map((f) => ({\n        \"@type\": \"Question\",\n        name: f.q,\n        acceptedAnswer: { \"@type\": \"Answer\", text: f.a },\n      })),\n    };\n\n    return [breadcrumb, webPage, serviceSchema, faqSchema];\n  }, [PAGE_URL, SEO_DESC, detailFaqs, intro, service]);\n\n  useEffect(() => {\n    const ensureTag = (selector, createFn) => {\n      let el = document.head.querySelector(selector);\n      if (!el) {\n        el = createFn();\n        document.head.appendChild(el);\n      }\n      return el;\n    };\n\n    document.title = SEO_TITLE;\n\n    ensureTag('meta[name=\"description\"]', () => {\n      const m = document.createElement(\"meta\");\n      m.setAttribute(\"name\", \"description\");\n      return m;\n    }).setAttribute(\"content\", SEO_DESC);\n\n    ensureTag('link[rel=\"canonical\"]', () => {\n      const l = document.createElement(\"link\");\n      l.setAttribute(\"rel\", \"canonical\");\n      return l;\n    }).setAttribute(\"href\", PAGE_URL);\n  }, [PAGE_URL, SEO_DESC, SEO_TITLE]);\n\n  if (!service) {\n    return (\n      <div className=\"max-w-4xl mx-auto px-4 py-16\">\n        <h1 className=\"text-3xl font-extrabold text-slate-900\">Service not found</h1>\n        <p className=\"mt-3 text-slate-600\">The requested service page does not exist.</p>\n        <Link to=\"/services\" className=\"mt-6 inline-block text-blue-600 font-semibold\">\n          Back to Services\n        </Link>\n      </div>\n    );\n  }\n\n  return (\n    <>\n      {schemas.map((obj, idx) => (\n        <script key={idx} type=\"application/ld+json\">\n          {JSON.stringify(obj)}\n        </script>\n      ))}\n\n      <section className=\"bg-gradient-to-b from-slate-50 to-white border-b\">\n        <div className=\"max-w-6xl mx-auto px-4 py-12 grid lg:grid-cols-2 gap-8 items-center\">\n          <div>\n            <nav className=\"text-sm text-slate-600\">\n              <Link to=\"/\" className=\"hover:text-slate-900\">Home</Link>\n              <span className=\"mx-2\">/</span>\n              <Link to=\"/services\" className=\"hover:text-slate-900\">Services</Link>\n              <span className=\"mx-2\">/</span>\n              <span className=\"text-slate-900 font-semibold\">{service.title}</span>\n            </nav>\n\n            <h1 className=\"mt-4 text-3xl md:text-4xl font-extrabold text-slate-900\">\n              {service.title} in Singapore\n            </h1>\n            <p className=\"mt-3 text-slate-600 leading-relaxed\">{intro}</p>\n\n            <div className=\"mt-4 flex flex-wrap gap-2\">\n              {[profile.primary, ...profile.secondary].map((k) => (\n                <span key={k} className=\"px-3 py-1 rounded-full text-xs font-semibold bg-slate-100 text-slate-700\">\n                  {k}\n                </span>\n              ))}\n            </div>\n\n            <div className=\"mt-6 flex gap-3 flex-wrap\">\n              <Link to=\"/contact\" className=\"px-5 py-3 rounded-xl bg-blue-600 text-white font-semibold hover:bg-blue-700 transition\">\n                Request a Quote\n              </Link>\n              <a href={`tel:${SITE.phone}`} className=\"px-5 py-3 rounded-xl bg-slate-900 text-white font-semibold hover:bg-slate-800 transition\">\n                Call Now\n              </a>\n            </div>\n          </div>\n\n          <div className=\"rounded-3xl overflow-hidden border bg-white shadow-sm\">\n            <img\n              src={service.heroImage || \"/images/glass.jpg\"}\n              alt={`${service.title} service in Singapore`}\n              className=\"h-64 sm:h-80 w-full object-cover\"\n              loading=\"lazy\"\n            />\n          </div>\n        </div>\n      </section>\n\n      <section className=\"max-w-6xl mx-auto px-4 py-12 grid lg:grid-cols-3 gap-8\">\n        <article className=\"lg:col-span-2\">\n          <h2 className=\"text-2xl font-extrabold text-slate-900\">\n            {service.title} - Service Details and Buying Guide\n          </h2>\n          <p className=\"mt-3 text-slate-600 leading-relaxed\">\n            This page is designed to help users compare options, understand installation approach, and decide faster with practical information.\n          </p>\n\n          <div className=\"mt-8 grid gap-6\">\n            {detailSections.map((sec) => (\n              <section key={sec.h} className=\"rounded-2xl border border-slate-200 bg-white p-6\">\n                <h3 className=\"text-lg font-extrabold text-slate-900\">{sec.h}</h3>\n                <p className=\"mt-2 text-slate-600 leading-relaxed\">{sec.p}</p>\n              </section>\n            ))}\n          </div>\n\n          <section className=\"mt-10\">\n            <h2 className=\"text-2xl font-extrabold text-slate-900\">Frequently Asked Questions - {service.title}</h2>\n            <div className=\"mt-6 grid gap-3\">\n              {detailFaqs.map((x) => (\n                <details key={x.q} className=\"group rounded-2xl border border-slate-200 bg-white p-5\">\n                  <summary className=\"cursor-pointer list-none font-bold text-slate-900 flex items-center justify-between\">\n                    <span>{x.q}</span>\n                    <span className=\"text-slate-400 group-open:rotate-180 transition\">v</span>\n                  </summary>\n                  <p className=\"mt-3 text-sm text-slate-600 leading-relaxed\">{x.a}</p>\n                </details>\n              ))}\n            </div>\n          </section>\n\n          <section className=\"mt-10\">\n            <h2 className=\"text-2xl font-extrabold text-slate-900\">Related Services</h2>\n            <div className=\"mt-4 grid sm:grid-cols-2 gap-3\">\n              {relatedServices.map((r) => (\n                <Link\n                  key={r.slug}\n                  to={`/services/${r.slug}`}\n                  className=\"rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700 hover:text-blue-700 hover:border-blue-200 transition\"\n                >\n                  {r.title}\n                </Link>\n              ))}\n            </div>\n          </section>\n\n          {relatedClusters.length ? (\n            <section className=\"mt-10\">\n              <h2 className=\"text-2xl font-extrabold text-slate-900\">Singapore Search Guides</h2>\n              <div className=\"mt-4 grid sm:grid-cols-2 gap-3\">\n                {relatedClusters.map((cluster) => (\n                  <Link\n                    key={cluster.slug}\n                    to={`/services/${cluster.slug}`}\n                    className=\"rounded-xl border border-slate-200 bg-slate-50 px-4 py-4 text-sm font-semibold text-slate-700 hover:border-blue-200 hover:bg-blue-50 hover:text-blue-700 transition\"\n                  >\n                    {cluster.title}\n                  </Link>\n                ))}\n              </div>\n            </section>\n          ) : null}\n        </article>\n\n        <aside className=\"lg:col-span-1\">\n          <div className=\"sticky top-24 space-y-4\">\n            <div className=\"rounded-2xl border border-slate-200 bg-white p-6\">\n              <h3 className=\"text-lg font-extrabold text-slate-900\">Need Fast Quotation?</h3>\n              <p className=\"mt-2 text-sm text-slate-600\">\n                Share postcode, photos and size. We will recommend a suitable solution quickly.\n              </p>\n              <a\n                href={`tel:${SITE.phone}`}\n                className=\"mt-4 inline-block w-full text-center px-5 py-3 rounded-xl bg-slate-900 text-white font-semibold hover:bg-slate-800 transition\"\n              >\n                Call {SITE.phone}\n              </a>\n              <Link\n                to=\"/contact\"\n                className=\"mt-3 inline-block w-full text-center px-5 py-3 rounded-xl border border-slate-300 text-slate-900 font-semibold hover:bg-slate-50 transition\"\n              >\n                Contact Form\n              </Link>\n              <Link\n                to=\"/projects\"\n                className=\"mt-3 inline-block w-full text-center px-5 py-3 rounded-xl border border-blue-200 text-blue-700 font-semibold hover:bg-blue-50 transition\"\n              >\n                View Completed Projects\n              </Link>\n            </div>\n\n            <div className=\"rounded-2xl border border-slate-200 bg-white p-6\">\n              <h3 className=\"text-lg font-extrabold text-slate-900\">All Services</h3>\n              <ul className=\"mt-3 space-y-2 text-sm\">\n                {SERVICES.map((s) => (\n                  <li key={s.slug}>\n                    <Link\n                      className={`hover:text-blue-600 ${\n                        s.slug === service.slug ? \"text-slate-900 font-semibold\" : \"text-slate-600\"\n                      }`}\n                      to={`/services/${s.slug}`}\n                    >\n                      {s.title}\n                    </Link>\n                  </li>\n                ))}\n              </ul>\n            </div>\n          </div>\n        </aside>\n      </section>\n    </>\n  );\n}\n"],"file":"x"}▄␀␀false018__webpack_require__4046__webpack_require__48175/*! ./node_modules/react-refresh/runtime.js */ "./node_modules/react-refresh/runtime.js"333344__webpack_require__.$Refresh$.signature34939139344344548849056556764785668569_data_site__WEBPACK_IMPORTED_MODULE_4__.SITE1123611239_data_site__WEBPACK_IMPORTED_MODULE_4__.SITE11703117171177811786(0,react_router_dom__WEBPACK_IMPORTED_MODULE_2__.useParams)1180911824(0,_data_site__WEBPACK_IMPORTED_MODULE_4__.getServiceBySlug)1186211871(0,_data_site__WEBPACK_IMPORTED_MODULE_4__.serviceUrl)1189211895_data_site__WEBPACK_IMPORTED_MODULE_4__.SITE1199812001_data_site__WEBPACK_IMPORTED_MODULE_4__.SITE1203612039_data_site__WEBPACK_IMPORTED_MODULE_4__.SITE1218312186_data_site__WEBPACK_IMPORTED_MODULE_4__.SITE1226512268_data_site__WEBPACK_IMPORTED_MODULE_4__.SITE1229812304(0,react__WEBPACK_IMPORTED_MODULE_0__.useMemo)1237812384(0,react__WEBPACK_IMPORTED_MODULE_0__.useMemo)1249412500(0,react__WEBPACK_IMPORTED_MODULE_0__.useMemo)1260912615(0,react__WEBPACK_IMPORTED_MODULE_0__.useMemo)1272512731(0,react__WE