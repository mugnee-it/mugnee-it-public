C,KAAK,EAAE,EAAE,CAAC,EAAG;cAC1DG,MAAM,EAAC,QAAQ;cACfC,GAAG,EAAC,YAAY;cAAAd,QAAA,EACjB;YAED;cAAAI,QAAA,EAAAC,YAAA;cAAAC,UAAA;cAAAC,YAAA;YAAA,OAAG,CAAC,eACJtC,OAAA;cACEuC,SAAS,EAAC,0EAA0E;cACpFC,IAAI,EAAE,OAAO3C,IAAI,CAACyB,KAAK,CAACmB,OAAO,CAAC,KAAK,EAAE,EAAE,CAAC,EAAG;cAAAV,QAAA,EAC9C;YAED;cAAAI,QAAA,EAAAC,YAAA;cAAAC,UAAA;cAAAC,YAAA;YAAA,OAAG,CAAC;UAAA;YAAAH,QAAA,EAAAC,YAAA;YAAAC,UAAA;YAAAC,YAAA;UAAA,OACD,CAAC;QAAA;UAAAH,QAAA,EAAAC,YAAA;UAAAC,UAAA;UAAAC,YAAA;QAAA,OACH,CAAC,eAENtC,OAAA;UAAMuC,SAAS,EAAC,gDAAgD;UAAAR,QAAA,gBAC9D/B,OAAA;YAAKuC,SAAS,EAAC,2BAA2B;YAAAR,QAAA,gBACxC/B,OAAA;cAAOuC,SAAS,EAAC,6BAA6B;cAACO,WAAW,EAAC;YAAM;cAAAX,QAAA,EAAAC,YAAA;cAAAC,UAAA;cAAAC,YAAA;YAAA,OAAE,CAAC,eACpEtC,OAAA;cAAOuC,SAAS,EAAC,6BAA6B;cAACO,WAAW,EAAC;YAAkB;cAAAX,QAAA,EAAAC,YAAA;cAAAC,UAAA;cAAAC,YAAA;YAAA,OAAE,CAAC;UAAA;YAAAH,QAAA,EAAAC,YAAA;YAAAC,UAAA;YAAAC,YAAA;UAAA,OAC7E,CAAC,eACNtC,OAAA;YAAOuC,SAAS,EAAC,oCAAoC;YAACO,WAAW,EAAC;UAAO;YAAAX,QAAA,EAAAC,YAAA;YAAAC,UAAA;YAAAC,YAAA;UAAA,OAAE,CAAC,eAC5EtC,OAAA;YACEuC,SAAS,EAAC,kDAAkD;YAC5DO,WAAW,EAAC;UAAgF;YAAAX,QAAA,EAAAC,YAAA;YAAAC,UAAA;YAAAC,YAAA;UAAA,OAC7F,CAAC,eACFtC,OAAA;YACEgC,IAAI,EAAC,QAAQ;YACbO,SAAS,EAAC,+EAA+E;YAAAR,QAAA,EAC1F;UAED;YAAAI,QAAA,EAAAC,YAAA;YAAAC,UAAA;YAAAC,YAAA;UAAA,OAAQ,CAAC,eACTtC,OAAA;YAAGuC,SAAS,EAAC,wBAAwB;YAAAR,QAAA,EAAC;UAEtC;YAAAI,QAAA,EAAAC,YAAA;YAAAC,UAAA;YAAAC,YAAA;UAAA,OAAG,CAAC;QAAA;UAAAH,QAAA,EAAAC,YAAA;UAAAC,UAAA;UAAAC,YAAA;QAAA,OACA,CAAC;MAAA;QAAAH,QAAA,EAAAC,YAAA;QAAAC,UAAA;QAAAC,YAAA;MAAA,OACJ,CAAC,eAENtC,OAAA;QAAKuC,SAAS,EAAC,gDAAgD;QAAAR,QAAA,eAC7D/B,OAAA;UACES,KAAK,EAAC,yBAAyB;UAC/B8B,SAAS,EAAC,kBAAkB;UAC5BQ,OAAO,EAAC,MAAM;UACdC,cAAc,EAAC,4BAA4B;UAC3CC,GAAG,EAAE,iCAAiCC,kBAAkB,CACtDrD,IAAI,CAAC8B,WAAW,GAAG,IAAI,GAAG9B,IAAI,CAAC6C,QACjC,CAAC;QAAgB;UAAAP,QAAA,EAAAC,YAAA;UAAAC,UAAA;UAAAC,YAAA;QAAA,OAClB;MAAC;QAAAH,QAAA,EAAAC,YAAA;QAAAC,UAAA;QAAAC,YAAA;MAAA,OACC,CAAC;IAAA;MAAAH,QAAA,EAAAC,YAAA;MAAAC,UAAA;MAAAC,YAAA;IAAA,OACC,CAAC;EAAA,eACV,CAAC;AAEP;AAAClC,EAAA,CAxJuBD,OAAO;EAAA,QAM7BL,UAAU;AAAA;AAAAqD,EAAA,GANYhD,OAAO;AAAA,IAAAgD,EAAA;AAAAC,YAAA,CAAAD,EAAA,a","sourcesContent":["import { SITE } from \"../data/site\";\nimport usePageSeo from \"../hooks/usePageSeo\";\n\nexport default function Contact() {\n  const PAGE_URL = `${SITE.domain}/contact`;\n  const SEO_TITLE = \"Contact Din Lee Engineering | Quote for Awning, Roofing & Zip Track Singapore\";\n  const SEO_DESC =\n    \"Contact Din Lee Engineering Pte. Ltd. for awning, roofing, glass canopy, zip track and metal works quotation in Singapore. Call, WhatsApp or send your site details.\";\n\n  usePageSeo({\n    title: SEO_TITLE,\n    description: SEO_DESC,\n    canonicalUrl: PAGE_URL,\n    ogImage: `${SITE.domain}/images/company-logo.png`,\n  });\n\n  const faqSchema = {\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"FAQPage\",\n    mainEntity: [\n      {\n        \"@type\": \"Question\",\n        name: \"Do you provide site survey in Singapore?\",\n        acceptedAnswer: {\n          \"@type\": \"Answer\",\n          text: \"Yes. We provide site measurement and recommend suitable awning, roofing and shade solutions based on your space and budget.\",\n        },\n      },\n      {\n        \"@type\": \"Question\",\n        name: \"What services do you offer?\",\n        acceptedAnswer: {\n          \"@type\": \"Answer\",\n          text: \"We provide retractable awning, loop awning, rooftop awnings, glass canopy shelters, ACP, polycarbonate, aluminium fluted and zinc roofing, zip track, outdoor roller blinds, ceilings, metal works and renovation support.\",\n        },\n      },\n      {\n        \"@type\": \"Question\",\n        name: \"How to get a quotation?\",\n        acceptedAnswer: {\n          \"@type\": \"Answer\",\n          text: \"Send your location, required solution type, approximate size, and photos of the area. We will respond quickly with the next steps.\",\n        },\n      },\n    ],\n  };\n\n  const contactSchema = {\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"ContactPage\",\n    name: \"Contact Din Lee Engineering\",\n    url: PAGE_URL,\n    description: SEO_DESC,\n    mainEntity: {\n      \"@type\": \"LocalBusiness\",\n      name: SITE.brand,\n      telephone: SITE.phone,\n      email: SITE.emailPrimary,\n      address: {\n        \"@type\": \"PostalAddress\",\n        streetAddress: SITE.addressLine,\n        addressLocality: \"Singapore\",\n        postalCode: \"757700\",\n        addressCountry: \"SG\",\n      },\n    },\n  };\n\n  return (\n    <>\n      <script type=\"application/ld+json\">{JSON.stringify(faqSchema)}</script>\n      <script type=\"application/ld+json\">{JSON.stringify(contactSchema)}</script>\n\n      <section className=\"max-w-6xl mx-auto px-4 py-12 grid md:grid-cols-2 gap-10\">\n        <div>\n          <h1 className=\"text-3xl font-extrabold text-slate-900\">Contact Us</h1>\n          <p className=\"mt-3 text-slate-600\">\n            Fast quotation for awning, roofing, shade systems, zip track and outdoor blinds in Singapore.\n          </p>\n\n          <div className=\"mt-6 rounded-2xl border bg-white p-5 space-y-2 text-sm text-slate-700\">\n            <div>\n              <b>Phone:</b>{\" \"}\n              <a className=\"hover:underline\" href={`tel:${SITE.phone.replace(/\\s/g, \"\")}`}>\n                {SITE.phone}\n              </a>\n            </div>\n\n            <div>\n              <b>Office:</b> {SITE.addressLine}, {SITE.cityLine}\n            </div>\n\n            {SITE.emailPrimary ? (\n              <div>\n                <b>Email:</b>{\" \"}\n                <a className=\"hover:underline\" href={`mailto:${SITE.emailPrimary}`}>\n                  {SITE.emailPrimary}\n                </a>\n              </div>\n            ) : null}\n\n            <div className=\"pt-2 flex gap-2 flex-wrap\">\n              <a\n                className=\"inline-block px-4 py-2 rounded-xl bg-green-600 text-white font-semibold hover:opacity-95\"\n                href={`https://wa.me/${SITE.whatsapp.replace(/\\D/g, \"\")}`}\n                target=\"_blank\"\n                rel=\"noreferrer\"\n              >\n                WhatsApp Now\n              </a>\n              <a\n                className=\"inline-block px-4 py-2 rounded-xl border font-semibold hover:bg-slate-50\"\n                href={`tel:${SITE.phone.replace(/\\s/g, \"\")}`}\n              >\n                Call Now\n              </a>\n            </div>\n          </div>\n\n          <form className=\"mt-6 rounded-2xl border bg-white p-5 space-y-3\">\n            <div className=\"grid sm:grid-cols-2 gap-3\">\n              <input className=\"border rounded-xl px-4 py-3\" placeholder=\"Name\" />\n              <input className=\"border rounded-xl px-4 py-3\" placeholder=\"Phone / WhatsApp\" />\n            </div>\n            <input className=\"border rounded-xl px-4 py-3 w-full\" placeholder=\"Email\" />\n            <textarea\n              className=\"border rounded-xl px-4 py-3 w-full min-h-[120px]\"\n              placeholder=\"What do you need? (e.g., retractable awning, polycarbonate roof, zip track...)\"\n            />\n            <button\n              type=\"button\"\n              className=\"w-full px-5 py-3 rounded-xl bg-blue-600 text-white font-bold hover:opacity-95\"\n            >\n              Send Request\n            </button>\n            <p className=\"text-xs text-slate-500\">\n              Production a form submit EmailJS, WhatsApp redirect, or API endpoint connect.\n            </p>\n          </form>\n        </div>\n\n        <div className=\"rounded-2xl border overflow-hidden bg-slate-50\">\n          <iframe\n            title=\"Din Lee Engineering Map\"\n            className=\"w-full h-[520px]\"\n            loading=\"lazy\"\n            referrerPolicy=\"no-referrer-when-downgrade\"\n            src={`https://www.google.com/maps?q=${encodeURIComponent(\n              SITE.addressLine + \", \" + SITE.cityLine\n            )}&output=embed`}\n 