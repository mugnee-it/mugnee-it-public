rt { SITE } from \"../data/site\";\n\nfunction VisualCard({ title, note, src, fallback }) {\n  return (\n    <figure className=\"rounded-2xl border border-slate-200 bg-white overflow-hidden shadow-sm hover-lift\">\n      <img\n        src={src}\n        alt={title}\n        className=\"h-52 w-full object-cover\"\n        loading=\"lazy\"\n        onError={(e) => {\n          e.currentTarget.src = fallback;\n        }}\n      />\n      <figcaption className=\"p-4\">\n        <div className=\"text-sm font-bold text-slate-900\">{title}</div>\n        <div className=\"mt-1 text-xs text-slate-600\">{note}</div>\n      </figcaption>\n    </figure>\n  );\n}\n\nexport default function About() {\n  const PAGE_URL = `${SITE.domain}/about`;\n  const SEO_TITLE = \"About Din Lee Engineering | Awning, Roofing & Shade Contractor Singapore\";\n  const SEO_DESC =\n    \"Learn about Din Lee Engineering Pte. Ltd., our team, process, service quality and project approach for awning, roofing, zip track and metal works in Singapore.\";\n\n  const imagePack = useMemo(\n    () => ({\n      hero: {\n        src: \"https://images.pexels.com/photos/5691626/pexels-photo-5691626.jpeg?auto=compress&cs=tinysrgb&w=1600\",\n        fallback: \"/images/glass-3.jpg\",\n      },\n      survey: {\n        src: \"https://images.pexels.com/photos/8961259/pexels-photo-8961259.jpeg?auto=compress&cs=tinysrgb&w=1200\",\n        fallback: \"/images/process.png\",\n      },\n      install: {\n        src: \"https://images.pexels.com/photos/5691659/pexels-photo-5691659.jpeg?auto=compress&cs=tinysrgb&w=1200\",\n        fallback: \"/images/ACP-Roofing-with-Metal-Structure.png\",\n      },\n      finish: {\n        src: \"https://images.pexels.com/photos/6474348/pexels-photo-6474348.jpeg?auto=compress&cs=tinysrgb&w=1200\",\n        fallback: \"/images/Glass-Roof-Canopy.png\",\n      },\n    }),\n    []\n  );\n\n  const schemas = useMemo(() => {\n    const breadcrumb = {\n      \"@context\": \"https://schema.org\",\n      \"@type\": \"BreadcrumbList\",\n      itemListElement: [\n        { \"@type\": \"ListItem\", position: 1, name: \"Home\", item: SITE.domain },\n        { \"@type\": \"ListItem\", position: 2, name: \"About\", item: PAGE_URL },\n      ],\n    };\n\n    const aboutPage = {\n      \"@context\": \"https://schema.org\",\n      \"@type\": \"AboutPage\",\n      name: \"About Din Lee Engineering\",\n      url: PAGE_URL,\n      description: SEO_DESC,\n      isPartOf: { \"@type\": \"WebSite\", name: SITE.brand, url: SITE.domain },\n    };\n\n    const localBusiness = {\n      \"@context\": \"https://schema.org\",\n      \"@type\": \"LocalBusiness\",\n      name: SITE.brand,\n      url: SITE.domain,\n      telephone: SITE.phone,\n      email: SITE.emailPrimary,\n      address: {\n        \"@type\": \"PostalAddress\",\n        streetAddress: SITE.addressLine,\n        addressLocality: \"Singapore\",\n        postalCode: \"757700\",\n        addressCountry: \"SG\",\n      },\n      areaServed: \"Singapore\",\n    };\n\n    return [breadcrumb, aboutPage, localBusiness];\n  }, [PAGE_URL, SEO_DESC]);\n\n  useEffect(() => {\n    const ensureTag = (selector, createFn) => {\n      let el = document.head.querySelector(selector);\n      if (!el) {\n        el = createFn();\n        document.head.appendChild(el);\n      }\n      return el;\n    };\n\n    document.title = SEO_TITLE;\n\n    const desc = ensureTag('meta[name=\"description\"]', () => {\n      const m = document.createElement(\"meta\");\n      m.setAttribute(\"name\", \"description\");\n      return m;\n    });\n    desc.setAttribute(\"content\", SEO_DESC);\n\n    const canonical = ensureTag('link[rel=\"canonical\"]', () => {\n      const l = document.createElement(\"link\");\n      l.setAttribute(\"rel\", \"canonical\");\n      return l;\n    });\n    canonical.setAttribute(\"href\", PAGE_URL);\n\n    const ogTitle = ensureTag('meta[property=\"og:title\"]', () => {\n      const m = document.createElement(\"meta\");\n      m.setAttribute(\"property\", \"og:title\");\n      return m;\n    });\n    ogTitle.setAttribute(\"content\", SEO_TITLE);\n\n    const ogDesc = ensureTag('meta[property=\"og:description\"]', () => {\n      const m = document.createElement(\"meta\");\n      m.setAttribute(\"property\", \"og:description\");\n      return m;\n    });\n    ogDesc.setAttribute(\"content\", SEO_DESC);\n\n    const ogUrl = ensureTag('meta[property=\"og:url\"]', () => {\n      const m = document.createElement(\"meta\");\n      m.setAttribute(\"property\", \"og:url\");\n      return m;\n    });\n    ogUrl.setAttribute(\"content\", PAGE_URL);\n  }, [PAGE_URL, SEO_DESC, SEO_TITLE]);\n\n  return (\n    <>\n      {schemas.map((obj, idx) => (\n        <script key={idx} type=\"application/ld+json\">\n          {JSON.stringify(obj)}\n        </script>\n      ))}\n\n      <section className=\"bg-gradient-to-b from-slate-50 to-white border-b\">\n        <div className=\"max-w-6xl mx-auto px-4 py-12 grid lg:grid-cols-2 gap-8 items-center\">\n          <div>\n            <h1 className=\"text-3xl md:text-4xl font-extrabold text-slate-900\">\n              About Din Lee Engineering\n            </h1>\n            <p className=\"mt-4 max-w-2xl text-slate-600 leading-relaxed\">\n              We are a Singapore-based contractor for awning, roofing, shade systems, zip track,\n              roller blind, canopy and custom metal works. Our work focuses on practical design,\n              durable materials and clean finishing for long-term performance in local weather.\n            </p>\n            <div className=\"mt-6 flex gap-3 flex-wrap\">\n              <Link\n                to=\"/services\"\n                className=\"px-5 py-3 rounded-xl bg-blue-600 text-white font-semibold hover:bg-blue-700 transition\"\n              >\n                Explore Services\n              </Link>\n              <Link\n                to=\"/contact\"\n                className=\"px-5 py-3 rounded-xl border border-slate-300 text-slate-900 font-semibold hover:bg-slate-50 transition\"\n              >\n                Contact Us\n              </Link>\n            </div>\n          </div>\n\n          <figure className=\"rounded-3xl overflow-hidden border border-slate-200 bg-white shadow-sm\">\n            <img\n              src={imagePack.hero.src}\n              alt=\"Awning and roofing team discussing site plan\"\n              className=\"h-72 md:h-80 w-full object-cover\"\n              onError={(e) => {\n                e.currentTarget.src = imagePack.hero.fallback;\n              }}\n            />\n            <figcaption className=\"px-5 py-3 text-sm text-slate-600 border-t\">\n              Visual reference: planning and execution workflow for outdoor projects.\n            </figcaption>\n          </figure>\n        </div>\n      </section>\n\n      <section className=\"max-w-6xl mx-auto px-4 py-12 grid md:grid-cols-2 gap-6\">\n        <article className=\"rounded-2xl border border-slate-200 bg-white p-6\">\n          <h2 className=\"text-xl font-extrabold text-slate-900\">Who We Are</h2>\n          <p className=\"mt-3 text-slate-600 leading-relaxed\">\n            Din Lee Engineering Pte. Ltd. supports residential, commercial and industrial projects\n            across Singapore. We deliver from site measurement to fabrication and installation.\n          </p>\n          <ul className=\"mt-4 space-y-2 text-slate-700\">\n            <li>Custom awning and roofing solutions</li>\n            <li>Glass canopy, zip track and roller blind systems</li>\n            <li>Metal framework and outdoor structure works</li>\n            <li>After-sales support and maintenance guidance</li>\n          </ul>\n        </article>\n\n        <article className=\"rounded-2xl border border-slate-200 bg-white p-6\">\n          <h2 className=\"text-xl font-extrabold text-slate-900\">How We Work</h2>\n          <ol className=\"mt-3 space-y-3 text-slate-600\">\n            <li>\n              <span className=\"font-semibold text-slate-900\">1. Site Survey:</span> We check\n              dimensions, mounting points, drainage direction and access.\n            </li>\n            <li>\n              <span className=\"font-semibold text-slate-900\">2. Proposal:</span> We recommend\n              suitable material and structure options based on use-case and budget.\n            </li>\n            <li>\n              <span className=\"font-semibold text-slate-900\">3. Fabrication & Installation:</span>{\" \"}\n              We execute with finishing checks for alignment, sealing and stability.\n            </li>\n          </ol>\n        </article>\n      </section>\n\n      <section className=\"max-w-6xl mx-auto px-4 pb-12\">\n        <h2 className=\"text-2xl font-extrabold text-slate-900\">What Users Can See at a Glance</h2>\n        <p className=\"mt-2 text-slate-600\">\n          We added clear visual examples so visitors quickly understand survey, installation and finishing quality.\n        </p>\n        <div className=\"mt-6 grid md:grid-cols-3 gap-4\">\n          <VisualCard\n            title=\"Site Survey and Measurement\"\n            note=\"Users understand that accurate measurement is done before quotation and fabrication.\"\n            src={imagePack.survey.src}\n            fallback={imagePack.survey.fallback}\n          />\n          <VisualCard\n            title=\"Installation Stage\"\n            note=\"Shows actual on-site fitting workflow and support structure alignment.\"\n            src={imagePack.install.src}\n            fallback={imagePack.install.fallback}\n          />\n          <VisualCard\n            title=\"Finishing and Handover\"\n            note=\"Highlights clean edges, neat sealing and finished look users care about.\"\n            src={imagePack.finish.src}\n            fallback={imagePack.finish.fallback}\n          />\n        </div>\n      </section>\n\n      <section className=\"bg-slate-50 border-y\">\n        <div className=\"max-w-6xl mx-auto px-4 py-12 grid lg:grid-cols-3 gap-6\">\n          <article className=\"lg:col-span-2 rounded-2xl border border-slate-200 bg-white p-6\">\n            <h2 className=\"text-xl font-extrabold text-slate-900\">Why Clients Choose Us</h2>\n            <div className=\"mt-4 grid sm:grid-cols-2 gap-4 text-slate-700\">\n              <div className=\"rounded-xl bg-slate-50 p-4\">Singapore weather-focused recommendations</div>\n              <div className=\"rounded-xl bg-slate-50 p-4\">Clear quotation and practical options</div>\n              <div className=\"rounded-xl bg-slate-50 p-4\">In-house workflow from measurement to handover</div>\n              <div className=\"rounded-xl bg-slate-50 p-4\">Responsive communication and support</div>\n            </div>\n          </article>\n\n          <aside className=\"rounded-2xl border border-slate-200 bg-white p-6\">\n            <h2 className=\"text-lg font-extrabold text-slate-900\">What We Prioritize</h2>\n            <p className=\"mt-3 text-sm text-slate-600 leading-relaxed\">\n              Each project is planned around site safety, weather resistance, drainage direction\n              and clean finishing so the result stays practical after handover.\n            </p>\n            <ul className=\"mt-4 space-y-2 text-sm text-slate-700\">\n              <li>Accurate site measurement before fabrication</li>\n              <li>Material selection based on real exposure conditions</li>\n              <li>Stable mounting, alignment and edge finishing</li>\n              <li>Clear communication on scope, timeline and care advice</li>\n            </ul>\n          </aside>\n        </div>\n      </section>\n    </>\n  );\n}\n"],"file":"x"}␀␀false018__webpack_require__4046__webpack_require__48175/*! ./node_modules/react-refresh/runtime.js */ "./node_modules/react-refresh/runtime.js"325336__webpack_require__.$Refresh$.signature341383385424426461463543629635(0,react_jsx_dev_runtime__WEBPACK_IMP