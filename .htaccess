Options -Indexes
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Cloudflare internal endpoints bypass
  RewriteRule ^cdn-cgi/ - [L,NC]

  # Force canonical host/protocol
  RewriteCond %{HTTP_HOST} ^www\.mugneeit\.com$ [NC,OR]
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://mugneeit.com%{REQUEST_URI} [L,R=301]

  # Canonicalize contact query variants used by legacy links
  RewriteCond %{REQUEST_URI} ^/contact/?$ [NC]
  RewriteCond %{QUERY_STRING} (^|&)service=[^&]+ [NC]
  RewriteRule ^contact/?$ /contact/? [L,R=301]

  # Remove /index.html from URLs
  RewriteCond %{THE_REQUEST} \s/+(.*/)?index\.html[\s?] [NC]
  RewriteRule ^ %1 [L,R=301]

  # Enforce trailing slash on clean URLs
  RewriteCond %{REQUEST_URI} !/$
  RewriteCond %{REQUEST_URI} !\.[a-zA-Z0-9]{1,6}$
  RewriteRule ^(.+)$ /$1/ [L,R=301]

  # Admin route should not be crawlable on production static hosting
  RewriteRule ^blog/admin/?$ - [G,L]

  # Serve existing files/folders directly
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Static export: /page -> /page.html (if exists)
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+)$ $1.html [L]

  # Static export: /page/ -> /page/index.html (if exists)
  RewriteCond %{REQUEST_FILENAME}/index.html -f
  RewriteRule ^(.+)$ $1/index.html [L]
</IfModule>

<IfModule mod_headers.c>
  Header always unset X-Robots-Tag
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  <FilesMatch "\.(woff2?|ttf|otf|eot)$">
    Header set X-Robots-Tag "noindex"
  </FilesMatch>

  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/plain text/html text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType font/woff2 "access plus 30 days"
</IfModule>
